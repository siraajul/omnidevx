---
const faqs = [
    {
        question: "How much does a typical project cost?",
        answer: "Every project is unique, but our MVP packages typically start at $25,000. Enterprise-scale AI integrations and full-stack platforms range from $50k to $150k+. We provide a highly detailed technical estimation before signing any contracts."
    },
    {
        question: "How long does it take to build an MVP?",
        answer: "Speed is our competitive advantage. We typically deliver a production-ready Minimum Viable Product in 4 to 8 weeks, depending on the complexity of the AI models and custom integrations required."
    },
    {
        question: "Do you sign NDAs?",
        answer: "Absolutely. We understand that intellectual property is your most valuable asset. We are happy to sign a Non-Disclosure Agreement before our very first discovery call."
    },
    {
        question: "What tech stack do you specialize in?",
        answer: "We primarily build with React/Next.js, Node.js, Python, and PostgreSQL, deployed on AWS or Vercel. For AI, we leverage OpenAI, Anthropic, LangChain, and Pinecone for vector search and RAG architecture."
    },
    {
        question: "Do you provide post-launch support?",
        answer: "Yes! We offer flexible retainer packages for ongoing maintenance, infrastructure scaling, and continuous feature development after your product goes live."
    }
];
---

<div class="max-w-3xl mx-auto relative z-10 w-full">
    {/* Contact Form */}
    <div class="bg-white/60 border border-[#e8e5db] p-8 md:p-12 rounded-[32px] backdrop-blur-xl gsap-reveal">
        <div class="text-center mb-8">
            <h3 class="text-3xl font-bold text-[#161616] mb-2">Send us a message</h3>
            <p class="text-[#2A2A2A]">You can also reach our technical sales team directly at <a href="mailto:hello@omnidevx.com" class="text-[#2A6FDB] font-medium hover:underline">hello@omnidevx.com</a></p>
        </div>
        
        <form class="flex flex-col gap-6" onsubmit="event.preventDefault(); alert('Form submitted! (This is a frontend demo)');">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="flex flex-col gap-2">
                    <label for="firstName" class="text-sm font-semibold text-[#2A2A2A] uppercase tracking-wider">First Name</label>
                    <input type="text" id="firstName" required class="bg-white/80 border border-[#e8e5db] rounded-xl px-4 py-3 text-[#161616] focus:outline-none focus:border-[#2A6FDB] focus:ring-1 focus:ring-[#2A6FDB] transition-all placeholder:text-[#444]" placeholder="John" />
                </div>
                <div class="flex flex-col gap-2">
                    <label for="lastName" class="text-sm font-semibold text-[#2A2A2A] uppercase tracking-wider">Last Name</label>
                    <input type="text" id="lastName" required class="bg-white/80 border border-[#e8e5db] rounded-xl px-4 py-3 text-[#161616] focus:outline-none focus:border-[#2A6FDB] focus:ring-1 focus:ring-[#2A6FDB] transition-all placeholder:text-[#444]" placeholder="Doe" />
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <label for="email" class="text-sm font-semibold text-[#2A2A2A] uppercase tracking-wider">Work Email</label>
                <input type="email" id="email" required class="bg-white/80 border border-[#e8e5db] rounded-xl px-4 py-3 text-[#161616] focus:outline-none focus:border-[#2A6FDB] focus:ring-1 focus:ring-[#2A6FDB] transition-all placeholder:text-[#444]" placeholder="john@company.com" />
            </div>

            <div class="flex flex-col gap-2">
                <label for="budget" class="text-sm font-semibold text-[#2A2A2A] uppercase tracking-wider">Project Budget</label>
                <select id="budget" class="bg-white/80 border border-[#e8e5db] rounded-xl px-4 py-3 text-[#161616] focus:outline-none focus:border-[#2A6FDB] focus:ring-1 focus:ring-[#2A6FDB] transition-all appearance-none cursor-pointer">
                    <option value="" disabled selected class="text-[#2A2A2A]">Select a range...</option>
                    <option value="10k-25k">$10k - $25k</option>
                    <option value="25k-50k">$25k - $50k</option>
                    <option value="50k-100k">$50k - $100k</option>
                    <option value="100k+">$100k+</option>
                </select>
            </div>

            <div class="flex flex-col gap-2">
                <label for="message" class="text-sm font-semibold text-[#2A2A2A] uppercase tracking-wider">Project Details</label>
                <textarea id="message" required rows="4" class="bg-white/80 border border-[#e8e5db] rounded-xl px-4 py-3 text-[#161616] focus:outline-none focus:border-[#2A6FDB] focus:ring-1 focus:ring-[#2A6FDB] transition-all placeholder:text-[#444] resize-none" placeholder="Tell us about your timeline, technical requirements, and ultimate goals..."></textarea>
            </div>

            <button type="submit" class="w-full mt-4 bg-[#111] text-white font-hand text-base py-4 rounded-xl hover:bg-[#2A6FDB] transition-all hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-2">
                submit inquiry
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
        </form>
    </div>
    </div>
</div>

<style>
    /* Tailwind utilities usually hide the default details marker, but this is a fallback */
    details > summary {
        list-style: none;
    }
    details > summary::-webkit-details-marker {
        display: none;
    }
    
    /* Smooth height animation for native details/summary */
    details[open] summary ~ * {
        animation: slideDown 0.3s ease-in-out;
    }
    
    @keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
