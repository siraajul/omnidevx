---
const metrics = [
    { number: "0", label: "Production Outages", index: "001" },
    { number: "10+", label: "Years Writing Code", index: "002" },
    { number: "14", label: "Engineers", index: "003" },
    { number: "10M+", label: "Lines of Code", index: "004" },
    { number: "100+", label: "Apps Shipped", index: "005" }
];
---

<section class="py-24 px-8 relative overflow-hidden bg-[#FDFCF7] border-y border-[#e8e5db]">
    {/* Abstract Background Element */}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-tr from-[#2A6FDB]/10 to-transparent blur-[120px] rounded-full pointer-events-none -z-10"></div>
    
    <div class="max-w-[90rem] mx-auto relative z-10">
        <h2 class="text-[12vw] leading-[0.8] font-display text-[#161616]/5 uppercase tracking-tighter absolute -top-12 left-0 -z-10 whitespace-nowrap pointer-events-none">
            We are<br />Omnidevx
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 mt-20">
            {metrics.map((metric) => (
                <div class="bg-white border border-[#e8e5db] p-8 rounded-2xl flex flex-col justify-between h-[320px] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group metric-card-reveal">
                    <span class="text-sm font-bold text-[#444] mb-8">{metric.index}</span>
                    <div class="mt-auto">
                        <p class="text-lg font-bold text-[#2A2A2A] mb-4">{metric.label}</p>
                        <p class="text-6xl font-display text-[#161616] group-hover:text-[#2A6FDB] transition-colors">{metric.number}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.metric-card-reveal');
	revealElements.forEach((el, index) => {
		gsap.from(el, {
			scrollTrigger: {
				trigger: el,
				start: 'top 85%',
			},
			y: 50,
			opacity: 0,
			duration: 0.6,
            delay: index * 0.1,
			ease: 'power3.out'
		});
	});
</script>
