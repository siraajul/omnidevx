---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';

const navItems = [
  { name: 'Services', href: '/#services' },
  { name: 'Process', href: '/process' },
  { name: 'Team', href: '/team' },
  { name: 'Contact', href: '/contact' },
];
---

<div class="fixed bottom-6 md:bottom-auto md:top-8 left-1/2 -translate-x-1/2 z-[100] w-max max-w-[95vw] pointer-events-none">
  <nav class="pointer-events-auto flex items-center gap-2 md:gap-4 px-2 py-2 md:px-4 md:py-3 bg-white/85 backdrop-blur-xl border border-zinc-200 rounded-full shadow-[0_20px_40px_-10px_rgba(0,0,0,0.15)] ring-1 ring-black/5">
    
    {!isHome && (
      <div class="flex items-center pr-3 sm:pr-4 border-r border-zinc-200">
        <a href="/" class="flex items-center gap-2 text-sm font-semibold text-zinc-900 hover:text-blue-600 transition-colors group">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-zinc-100 group-hover:bg-blue-50 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
          </span>
          <span class="hidden sm:inline">Back</span>
        </a>
      </div>
    )}

    <div class="flex items-center gap-1 sm:gap-2">
      {navItems.map(item => {
        // Hash links shouldn't show active state on the server side easily
        const isHash = item.href.includes('#');
        const isActive = !isHash && (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)));
        
        return (
          <a
            href={item.href}
            class={`text-[10px] sm:text-xs md:text-sm font-bold tracking-widest uppercase transition-all px-4 py-2 sm:px-5 sm:py-2.5 rounded-full ${
              isActive 
                ? 'text-blue-600 bg-blue-50/80 shadow-sm' 
                : 'text-zinc-500 hover:text-zinc-900 hover:bg-zinc-100/80'
            }`}
          >
            {item.name}
          </a>
        );
      })}
    </div>
    
  </nav>
</div>
