---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';

const navItems = [
  { name: 'Services', href: '/services' },
  { name: 'Process', href: '/process' },
  { name: 'Work', href: '/portfolio' },
  { name: 'Blog', href: '/blog' },
  { name: 'Contact', href: '/contact' },
];
---

<div class="fixed bottom-6 md:bottom-auto md:top-8 left-1/2 -translate-x-1/2 z-[100] w-max max-w-[95vw] pointer-events-none">
  <nav class="pointer-events-auto flex items-center gap-2 md:gap-3 px-2 py-1.5 md:px-3 md:py-2 bg-white/85 backdrop-blur-xl border border-[#e8e5db] rounded-full shadow-[0_20px_40px_-10px_rgba(0,0,0,0.12)] ring-1 ring-black/5" style="font-family: 'Kalam', cursive;">
    
    {/* Logo */}
    <div class="flex items-center pl-3 pr-3 sm:pr-4 border-r border-[#e8e5db]">
      <a href="/" aria-label="Omnidevx Home" class="flex items-center justify-center group">
        <span class="font-display text-2xl sm:text-3xl text-[#161616] group-hover:scale-105 transition-transform duration-300">
          omnidev<span class="text-[#2A6FDB]">X</span>
        </span>
      </a>
    </div>
    {!isHome && (
      <div class="flex items-center pr-3 sm:pr-4 border-r border-[#e8e5db]">
        <button onclick="window.history.length > 1 ? window.history.back() : window.location.href = '/';" class="flex items-center gap-2 text-sm font-normal text-[#161616] hover:text-[#2A6FDB] transition-colors group cursor-pointer">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-[#f5f3ea] group-hover:bg-blue-50 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
          </span>
          <span class="hidden sm:inline">Back</span>
        </button>
      </div>
    )}

    <div class="flex items-center gap-1 sm:gap-2">
      {navItems.map(item => {
        // Hash links shouldn't show active state on the server side easily
        const isHash = item.href.includes('#');
        const isActive = !isHash && (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)));
        
        return (
          <a
            href={item.href}
            class={`magnetic-nav text-[11px] sm:text-xs md:text-sm font-normal transition-all px-3 py-1.5 sm:px-4 sm:py-2 rounded-full inline-block ${
              isActive 
                ? 'text-[#2A6FDB] bg-blue-50/80 shadow-sm' 
                : 'text-[#444] hover:text-[#161616] hover:bg-[#f5f3ea]'
            }`}
          >
            {item.name}
          </a>
        );
      })}
    </div>
    
  </nav>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const magneticElements = document.querySelectorAll('.magnetic-nav, .group'); // include the back button and logo
    
    magneticElements.forEach((elem) => {
      // Cast to HTMLElement to access offset properties safely
      const htmlElem = elem as HTMLElement;
      
      htmlElem.addEventListener('mousemove', (e) => {
        const rect = htmlElem.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        // Gentle translation
        htmlElem.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
      });
      
      htmlElem.addEventListener('mouseleave', () => {
        // Reset translation
        htmlElem.style.transform = `translate(0px, 0px)`;
      });
    });
  });
</script>
