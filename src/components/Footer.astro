---
interface Props {
    ctaType?: "default" | "careers";
}
const { ctaType = "default" } = Astro.props;
const isCareers = ctaType === "careers";

const currentYear = new Date().getFullYear();
---
<footer class="relative w-full bg-[#FDFCF7] border-t border-[#e8e5db] pt-32 pb-8 overflow-hidden">
    {/* Subtle Background Glow */}
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[#2A6FDB]/8 blur-[120px] rounded-full pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-8 relative z-10">
        
        {/* Top CTA Area */}
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-24 gap-8">
            <div class="max-w-2xl">
                <h2 class="text-5xl md:text-6xl font-display text-[#161616] mb-6 leading-tight">
                    {isCareers ? (
                        <Fragment>Let's build the <br/>
                        <span class="scribble-underline text-[#2A6FDB]">future.</span></Fragment>
                    ) : (
                        <Fragment>Let's build the <br/>
                        <span class="scribble-underline text-[#2A6FDB]">impossible.</span></Fragment>
                    )}
                </h2>
                <p class="text-xl text-[#2A2A2A]">
                    {isCareers
                        ? "Join our elite engineering team and help us scale visions into reality."
                        : "Partner with our elite engineering team to scale your vision into reality."
                    }
                </p>
            </div>
            <a href={isCareers ? "mailto:careers@omnidevx.com" : "#"} class="group relative inline-flex items-center justify-center px-8 py-5 bg-[#111] text-white font-hand text-base rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(0,0,0,0.15)] shrink-0">
                <div class="absolute inset-0 bg-[#2A6FDB] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <span class="relative flex items-center gap-2">
                    {isCareers ? "send resume for future openings" : "estimate project →"}
                    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </span>
            </a>
        </div>

        {/* Links Grid */}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-12 mb-24" style="font-family: 'Kalam', cursive;">
            
            {/* Services */}
            <div class="flex flex-col gap-6">
                <h4 class="text-[#161616] font-bold text-xl tracking-wide">Services</h4>
                <ul class="flex flex-col gap-4 text-lg font-bold">
                    <li><a href="/services/ai-mvp" class="text-[#444] hover:text-[#2A6FDB] transition-colors relative group w-fit">AI-Powered MVP <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="/services/generative-ai" class="text-[#444] hover:text-[#2A6FDB] transition-colors relative group w-fit">Generative AI <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="/services/web-development" class="text-[#444] hover:text-[#2A6FDB] transition-colors relative group w-fit">Web Engineering <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="/services/mobile-development" class="text-[#444] hover:text-[#2A6FDB] transition-colors relative group w-fit">Mobile Apps <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="/services/devops-sqa" class="text-[#444] hover:text-[#2A6FDB] transition-colors relative group w-fit">DevOps & SQA <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                </ul>
            </div>

            {/* Company */}
            <div class="flex flex-col gap-6">
                <h4 class="text-[#161616] font-bold text-xl tracking-wide">Company</h4>
                <ul class="flex flex-col gap-4 text-lg font-bold">
                    <li><a href="/#process" class="text-[#444] hover:text-[#161616] transition-colors relative group w-fit">Our Process <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="/portfolio" class="text-[#444] hover:text-[#161616] transition-colors relative group w-fit">Portfolio <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="/team" class="text-[#444] hover:text-[#161616] transition-colors relative group w-fit">The Team <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="/culture" class="text-[#444] hover:text-[#161616] transition-colors relative group w-fit">Culture <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li>
                        <a href="/careers" class="text-[#444] hover:text-[#161616] transition-colors relative group flex items-center gap-2 w-fit">
                            Careers 
                            <span class="bg-[#e8f0fd] text-[#2A6FDB] text-[9px] px-2 py-0.5 rounded-full font-bold">Hiring</span>
                            <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span>
                        </a>
                    </li>
                </ul>
            </div>

            {/* Socials */}
            <div class="flex flex-col gap-6">
                <h4 class="text-[#161616] font-bold text-xl tracking-wide">Connect</h4>
                <ul class="flex flex-col gap-4 text-lg font-bold">
                    <li><a href="#" class="text-zinc-500 hover:text-[#2A6FDB] transition-colors relative group flex items-center gap-2 w-fit"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg> LinkedIn <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#2A6FDB] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="#" class="text-[#444] hover:text-[#161616] transition-colors relative group flex items-center gap-2 w-fit"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg> Twitter / X <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#161616] transition-all duration-300 group-hover:w-full"></span></a></li>
                    <li><a href="#" class="text-[#444] hover:text-[#161616] transition-colors relative group flex items-center gap-2 w-fit"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg> GitHub <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#161616] transition-all duration-300 group-hover:w-full"></span></a></li>
                </ul>
            </div>

            {/* Contact */}
            <div class="flex flex-col gap-6 col-span-2 md:col-span-1 items-center md:items-start text-center md:text-left">
                <h4 class="text-[#161616] font-bold text-xl tracking-wide">Reach Out</h4>
                <div class="flex flex-col gap-4 text-lg font-bold text-[#444] items-center md:items-start">
                    <p class="text-[#161616] hover:text-[#2A6FDB] transition-colors cursor-pointer">hello@omnidevx.com</p>
                    <p>100 Innovation Drive<br/>San Francisco, CA 94111</p>
                    <div class="mt-2 flex items-center justify-center md:justify-start gap-2">
                        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                        <span class="text-xs uppercase tracking-wider text-zinc-500">Available for new projects</span>
                    </div>
                </div>
            </div>

        </div>

        {/* Massive Brand Name Background */}
        <div class="w-full flex justify-center py-4 md:py-8">
            <span class="inline-block text-[14vw] font-display select-none leading-none pt-4 pb-16 bg-clip-text text-transparent bg-gradient-to-b from-[#e8e5db] to-[#FDFCF7]">
                omnidevx
            </span>
        </div>

        {/* Bottom Bar */}
        <div class="border-t border-[#e8e5db] pt-8 flex flex-col md:flex-row justify-between items-center gap-4" style="font-family: 'Kalam', cursive;">
            <p class="text-[#444] text-sm">
                &copy; {currentYear} omnidevx. All rights reserved.
            </p>
            <div class="flex gap-8">
                <a href="/privacy" class="text-[#444] hover:text-[#161616] transition-colors text-sm relative group">Privacy Policy <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#161616] transition-all duration-300 group-hover:w-full"></span></a>
                <a href="/terms" class="text-[#444] hover:text-[#161616] transition-colors text-sm relative group">Terms of Service <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#161616] transition-all duration-300 group-hover:w-full"></span></a>
            </div>
        </div>
    </div>
</footer>
