---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="relative w-full min-h-screen bg-black pt-32 pb-16 px-8">
		<div class="max-w-7xl mx-auto">
			<h1 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-600 mb-6">
				Our Process
			</h1>
			<p class="text-xl text-zinc-400 max-w-2xl mb-16">
				How we turn complex requirements into elegant, high-performing software solutions.
			</p>
			
			<div class="relative border-l border-zinc-800 pl-8 ml-4 space-y-16">
				{/* Timeline Placeholders */}
				<div class="relative">
                    <div class="absolute -left-[41px] top-1 w-6 h-6 bg-black border-2 border-indigo-500 rounded-full"></div>
					<h3 class="text-3xl font-bold text-white mb-3">1. Discovery & Strategy</h3>
					<p class="text-zinc-400 text-lg">We dive deep into your business goals, target audience, and technical constraints to architect the perfect solution.</p>
				</div>
                <div class="relative">
                    <div class="absolute -left-[41px] top-1 w-6 h-6 bg-black border-2 border-purple-500 rounded-full"></div>
					<h3 class="text-3xl font-bold text-white mb-3">2. Design & Architecture</h3>
					<p class="text-zinc-400 text-lg">Creating intuitive UX/UI designs and planning the scalable database schemas and API infrastructure.</p>
				</div>
                <div class="relative">
                    <div class="absolute -left-[41px] top-1 w-6 h-6 bg-black border-2 border-indigo-500 rounded-full"></div>
					<h3 class="text-3xl font-bold text-white mb-3">3. Agile Development</h3>
					<p class="text-zinc-400 text-lg">Iterative coding sprints with continuous integration, ensuring transparent progress and rapid feedback loops.</p>
				</div>
                 <div class="relative">
                    <div class="absolute -left-[41px] top-1 w-6 h-6 bg-black border-2 border-purple-500 rounded-full"></div>
					<h3 class="text-3xl font-bold text-white mb-3">4. Launch & Scale</h3>
					<p class="text-zinc-400 text-lg">Deployment, performance monitoring via Datadog, and ongoing support to ensure maximum uptime.</p>
				</div>
			</div>
		</div>
	</main>
</Layout>
