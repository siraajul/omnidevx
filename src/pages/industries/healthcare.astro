---
import Layout from '../../layouts/Layout.astro';
import { AnimatedProcessFlow } from '../../components/sections/animated-process-flow';
---

<Layout title="Healthcare Software Development Agency | Omnidevx" ogImage="/og/industries.png" description="Build HIPAA-compliant, secure, and scalable healthcare applications, telemedicine platforms, and EHR integrations.">
	<main class="relative w-full overflow-hidden bg-[#FDFCF7]">
		
		{/* HERO SECTION */}
		<div class="flex flex-col overflow-hidden pt-32 pb-20 px-8 relative">
            <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-emerald-50/50 to-transparent -z-10"></div>
			<div class="max-w-5xl mx-auto text-center">
                <span class="inline-block px-4 py-2 bg-emerald-100 text-emerald-700 font-bold tracking-widest uppercase text-sm rounded-full mb-6">Healthcare & Life Sciences</span>
				<h1 class="text-4xl md:text-6xl font-display text-[#161616] mb-8 leading-tight">
					Secure, Compliant & Scalable <br />
					<span class="text-emerald-600 scribble-underline">Healthcare Software</span>
				</h1>
				<p class="text-xl text-[#2A2A2A] max-w-3xl mx-auto mb-12">
					We build HIPAA-compliant telemedicine platforms, patient portals, and seamless EHR integrations that modernize patient care without compromising security.
				</p>
				<div class="flex justify-center gap-4">
					<a href="/contact" class="px-8 py-4 bg-[#161616] text-[#FDFCF7] rounded-full font-bold hover:bg-[#2A2A2A] transition-colors">
						Discuss Your Project
					</a>
				</div>
			</div>
		</div>

        {/* INDUSTRY CHALLENGES */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-white">
			<div class="max-w-6xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
                    <div class="gsap-reveal">
                        <h2 class="text-3xl md:text-5xl font-display text-[#161616] mb-6 leading-tight">The stakes are higher in <span class="text-emerald-600">HealthTech.</span></h2>
                        <p class="text-lg text-[#444] mb-8 leading-relaxed">
                            Building software for healthcare isn't just about writing code. It's about navigating a minefield of regulatory compliance, legacy systems, and life-or-death security requirements.
                        </p>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-4">
                                <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0 mt-1"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></div>
                                <div>
                                    <h4 class="font-bold text-[#161616]">Strict HIPAA Audits</h4>
                                    <p class="text-sm text-[#444]">A single data breach can result in millions of dollars in fines and destroyed reputation.</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4">
                                <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0 mt-1"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></div>
                                <div>
                                    <h4 class="font-bold text-[#161616]">Fragmented Legacy EHRs</h4>
                                    <p class="text-sm text-[#444]">Extracting data from 20-year-old hospital systems requires deep expertise in HL7 and FHIR protocols.</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4">
                                <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0 mt-1"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                                <div>
                                    <h4 class="font-bold text-[#161616]">The Omnidevx Solution</h4>
                                    <p class="text-sm text-[#444]">We engineer systems with compliance built into the infrastructure layer from day one, not as an afterthought.</p>
                                </div>
                            </li>
                        </ul>
                    </div>
                    <div class="relative gsap-reveal rounded-3xl overflow-hidden shadow-2xl border border-[#e8e5db]">
                        <img src="https://images.unsplash.com/photo-1576091160550-2173ff9e5eb8?q=80&w=2000&auto=format&fit=crop" alt="Medical Technology" class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-gradient-to-t from-[#161616]/80 to-transparent flex items-end p-8">
                            <p class="text-white font-medium text-lg border-l-4 border-emerald-500 pl-4">"Omnidevx completely overhauled our patient portal architecture to be 100% HIPAA compliant while speeding up load times by 400%."</p>
                        </div>
                    </div>
                </div>
			</div>
		</section>

		{/* WHAT WE BUILD (Detailed Solutions) */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-[#FDFCF7]">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16 gsap-reveal">
					<h2 class="text-3xl md:text-4xl font-display text-[#161616] mb-4">What We <span class="text-emerald-600">Build</span></h2>
					<p class="text-[#444] max-w-2xl mx-auto">From clinical tools to patient-facing applications.</p>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="p-8 border border-[#e8e5db] rounded-3xl bg-white hover:border-emerald-600 transition-colors shadow-sm gsap-reveal">
						<div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-xl flex items-center justify-center mb-6">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
						</div>
						<h3 class="text-xl font-bold text-[#161616] mb-3">Telemedicine Platforms</h3>
						<p class="text-[#444] mb-4">High-definition WebRTC video infrastructure, automated scheduling systems, and secure asynchronous messaging for remote patient care.</p>
                        <ul class="text-sm text-[#444] space-y-2">
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div> WebRTC Video Streaming</li>
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div> E-Prescription APIs</li>
                        </ul>
					</div>
					<div class="p-8 border border-[#e8e5db] rounded-3xl bg-white hover:border-emerald-600 transition-colors shadow-sm gsap-reveal">
						<div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-xl flex items-center justify-center mb-6">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
						</div>
						<h3 class="text-xl font-bold text-[#161616] mb-3">EHR Integrations</h3>
						<p class="text-[#444] mb-4">Seamless, bi-directional data syncing with Epic, Cerner, and Athenahealth using standardized HL7 and FHIR protocols.</p>
                        <ul class="text-sm text-[#444] space-y-2">
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div> FHIR & HL7 Standard</li>
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div> Epic / Cerner Sync</li>
                        </ul>
					</div>
                    <div class="p-8 border border-[#e8e5db] rounded-3xl bg-white hover:border-emerald-600 transition-colors shadow-sm gsap-reveal">
						<div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-xl flex items-center justify-center mb-6">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<h3 class="text-xl font-bold text-[#161616] mb-3">Patient Portals</h3>
						<p class="text-[#444] mb-4">Intuitive mobile and web apps that empower patients to view lab results, pay bills, and communicate securely with providers.</p>
                        <ul class="text-sm text-[#444] space-y-2">
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div> React Native iOS/Android</li>
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div> Push Notifications</li>
                        </ul>
					</div>
				</div>
			</div>
		</section>

        {/* SPECIALIZED TECH STACK */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-[#161616] text-[#FDFCF7]">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16 gsap-reveal">
					<h2 class="text-3xl md:text-4xl font-display mb-4">Compliance-First <span class="text-emerald-500">Infrastructure</span></h2>
					<p class="text-zinc-400 max-w-2xl mx-auto">We utilize modern cloud infrastructure hardened for PHI.</p>
				</div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
                    <div class="p-6 border border-zinc-800 rounded-2xl bg-zinc-900/50 gsap-reveal">
                        <div class="font-bold text-xl mb-2 text-white">AWS GovCloud</div>
                        <p class="text-xs text-zinc-400">Isolated, compliance-ready server environments.</p>
                    </div>
                    <div class="p-6 border border-zinc-800 rounded-2xl bg-zinc-900/50 gsap-reveal">
                        <div class="font-bold text-xl mb-2 text-white">Vanta / Drata</div>
                        <p class="text-xs text-zinc-400">Continuous SOC2 & HIPAA compliance monitoring.</p>
                    </div>
                    <div class="p-6 border border-zinc-800 rounded-2xl bg-zinc-900/50 gsap-reveal">
                        <div class="font-bold text-xl mb-2 text-white">PostgreSQL (AES-256)</div>
                        <p class="text-xs text-zinc-400">Data encrypted at rest and in transit.</p>
                    </div>
                    <div class="p-6 border border-zinc-800 rounded-2xl bg-zinc-900/50 gsap-reveal">
                        <div class="font-bold text-xl mb-2 text-white">Datadog</div>
                        <p class="text-xs text-zinc-400">Comprehensive audit logging and access tracking.</p>
                    </div>
                </div>
            </div>
        </section>

		{/* HOW WE APPROACH IT */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-white">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl font-bold text-[#161616] mb-16 text-center gsap-reveal">Development Pipeline</h2>
				<AnimatedProcessFlow type="standard" client:visible />
			</div>
		</section>

        {/* FAQ SECTION */}
        <section class="py-24 px-8 border-t border-[#e8e5db] bg-[#FDFCF7]">
            <div class="max-w-3xl mx-auto gsap-reveal">
                <h2 class="text-3xl font-display text-[#161616] mb-12 text-center">Frequently Asked <span class="text-emerald-600">Questions</span></h2>
                <div class="space-y-4">
                    <details class="group bg-white border border-[#e8e5db] rounded-2xl p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer shadow-sm hover:border-emerald-600 transition-colors">
                        <summary class="flex justify-between items-center font-bold text-lg text-[#161616]">
                            Do you sign Business Associate Agreements (BAAs)?
                            <span class="transition group-open:rotate-180">
                                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                            </span>
                        </summary>
                        <p class="text-[#444] mt-4 leading-relaxed animate-fade-in">
                            Yes. Before we access any production environments or handle PHI, we execute rigorous Business Associate Agreements. We also ensure that all 3rd party tools we utilize (AWS, Vercel, Postgres providers) have signed BAAs in place.
                        </p>
                    </details>
                    <details class="group bg-white border border-[#e8e5db] rounded-2xl p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer shadow-sm hover:border-emerald-600 transition-colors">
                        <summary class="flex justify-between items-center font-bold text-lg text-[#161616]">
                            How do you handle legacy EHR integration?
                            <span class="transition group-open:rotate-180">
                                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                            </span>
                        </summary>
                        <p class="text-[#444] mt-4 leading-relaxed animate-fade-in">
                            We utilize modern integration engines like Redox or build custom middleware to interface directly with older HL7 protocols, translating them into secure REST or GraphQL APIs for modern web and mobile clients.
                        </p>
                    </details>
                    <details class="group bg-white border border-[#e8e5db] rounded-2xl p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer shadow-sm hover:border-emerald-600 transition-colors">
                        <summary class="flex justify-between items-center font-bold text-lg text-[#161616]">
                            Can you build FDA-compliant software (SaMD)?
                            <span class="transition group-open:rotate-180">
                                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                            </span>
                        </summary>
                        <p class="text-[#444] mt-4 leading-relaxed animate-fade-in">
                            Yes. For Software as a Medical Device (SaMD), we follow strict IEC 62304 guidelines, implementing comprehensive traceability matrices, risk management protocols, and rigorous SQA testing phases.
                        </p>
                    </details>
                </div>
            </div>
        </section>

		{/* CTA */}
		<section class="py-24 px-8 border-t border-[#e8e5db] text-center bg-white">
			<div class="max-w-2xl mx-auto gsap-reveal">
				<h2 class="text-3xl md:text-4xl font-display text-[#161616] mb-4">Ready to build your <span class="text-emerald-600">HealthTech</span> solution?</h2>
				<p class="text-[#444] mb-8">Schedule a discovery call to discuss compliance requirements and technical architecture.</p>
				<a href="/contact" class="inline-flex items-center gap-2 px-10 py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-full transition-colors text-lg">
					Talk to our Engineers →
				</a>
			</div>
		</section>

	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: { trigger: el, start: 'top 85%' },
			y: 40, opacity: 0, duration: 0.8, ease: 'power3.out'
		});
	});
</script>
<style>
    .animate-fade-in {
        animation: fadeIn 0.3s ease-in-out;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
