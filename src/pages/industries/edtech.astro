---
import Layout from '../../layouts/Layout.astro';
import { AnimatedProcessFlow } from '../../components/sections/animated-process-flow';
---

<Layout title="EdTech & E-Learning Platform Development | Omnidevx" ogImage="/og/industries.png" description="Build highly concurrent e-learning platforms, adaptive video streaming, and scalable exam infrastructure.">
	<main class="relative w-full overflow-hidden bg-[#FDFCF7]">
		
		{/* HERO SECTION */}
		<div class="flex flex-col overflow-hidden pt-32 pb-20 px-8 relative">
            <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-amber-50/50 to-transparent -z-10"></div>
			<div class="max-w-5xl mx-auto text-center">
                <span class="inline-block px-4 py-2 bg-amber-100 text-amber-700 font-bold tracking-widest uppercase text-sm rounded-full mb-6">EdTech & E-Learning</span>
				<h1 class="text-4xl md:text-6xl font-display text-[#161616] mb-8 leading-tight">
					Scalable Infrastructure <br />
					<span class="text-amber-600 scribble-underline">for EdTech</span>
				</h1>
				<p class="text-xl text-[#2A2A2A] max-w-3xl mx-auto mb-12">
					We engineer e-learning platforms that survive the morning login rush. Video streaming, real-time collaboration, and analytics infrastructure that doesn't crash when thousands of students log on simultaneously.
				</p>
				<div class="flex justify-center gap-4">
					<a href="/contact" class="px-8 py-4 bg-[#161616] text-[#FDFCF7] rounded-full font-bold hover:bg-[#2A2A2A] transition-colors">
						Scale Your Platform
					</a>
				</div>
			</div>
		</div>

        {/* INDUSTRY CHALLENGES */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-white">
			<div class="max-w-6xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
                    <div class="gsap-reveal">
                        <h2 class="text-3xl md:text-5xl font-display text-[#161616] mb-6 leading-tight">Concurrency is the killer <span class="text-amber-600">of EdTech.</span></h2>
                        <p class="text-lg text-[#444] mb-8 leading-relaxed">
                            Building a video course is easy. Building a platform that handles 50,000 students taking a high-stakes exam at the exact same second requires serious engineering.
                        </p>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-4">
                                <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0 mt-1"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></div>
                                <div>
                                    <h4 class="font-bold text-[#161616]">The Thundering Herd</h4>
                                    <p class="text-sm text-[#444]">When 100 schools log in at 9:00 AM sharp, monolithic architectures collapse under the sudden spike in database connections.</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4">
                                <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0 mt-1"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg></div>
                                <div>
                                    <h4 class="font-bold text-[#161616]">Video Bandwidth Costs</h4>
                                    <p class="text-sm text-[#444]">Unoptimized video delivery not only ruins the learning experience for students on slow connections but also bankrupts your AWS account.</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-4">
                                <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center flex-shrink-0 mt-1"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
                                <div>
                                    <h4 class="font-bold text-[#161616]">The Omnidevx Solution</h4>
                                    <p class="text-sm text-[#444]">We utilize edge caching, serverless scaling, and optimized CDNs to ensure your platform remains responsive, no matter the load.</p>
                                </div>
                            </li>
                        </ul>
                    </div>
                    <div class="relative gsap-reveal rounded-3xl overflow-hidden shadow-2xl border border-[#e8e5db]">
                        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=2000&auto=format&fit=crop" alt="Students learning" class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-gradient-to-t from-[#161616]/80 to-transparent flex items-end p-8">
                            <p class="text-white font-medium text-lg border-l-4 border-amber-500 pl-4">"When our user base tripled during finals week, the serverless infrastructure Omnidevx built didn't drop a single connection."</p>
                        </div>
                    </div>
                </div>
			</div>
		</section>

		{/* WHAT WE BUILD (Detailed Solutions) */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-[#FDFCF7]">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16 gsap-reveal">
					<h2 class="text-3xl md:text-4xl font-display text-[#161616] mb-4">EdTech Systems We <span class="text-amber-600">Build</span></h2>
					<p class="text-[#444] max-w-2xl mx-auto">The unglamorous, highly technical scaffolding required to run a real educational platform.</p>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="p-8 border border-[#e8e5db] rounded-3xl bg-white hover:border-amber-600 transition-colors shadow-sm gsap-reveal">
						<div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center mb-6">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
						</div>
						<h3 class="text-xl font-bold text-[#161616] mb-3">High-Concurrency Exams</h3>
						<p class="text-[#444] mb-4">Implementing Redis-backed queuing and auto-scaling groups to process millions of concurrent exam submissions without dropping data.</p>
                        <ul class="text-sm text-[#444] space-y-2">
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div> Redis Queuing</li>
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div> Serverless Auto-scaling</li>
                        </ul>
					</div>
					<div class="p-8 border border-[#e8e5db] rounded-3xl bg-white hover:border-amber-600 transition-colors shadow-sm gsap-reveal">
						<div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center mb-6">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
						</div>
						<h3 class="text-xl font-bold text-[#161616] mb-3">Adaptive Video Streaming</h3>
						<p class="text-[#444] mb-4">Encoding and delivering HLS/DASH video streams through edge networks to provide seamless playback regardless of the student's internet connection.</p>
                        <ul class="text-sm text-[#444] space-y-2">
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div> HLS Video Encoding</li>
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div> Global CDN Caching</li>
                        </ul>
					</div>
					<div class="p-8 border border-[#e8e5db] rounded-3xl bg-white hover:border-amber-600 transition-colors shadow-sm gsap-reveal">
						<div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center mb-6">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
						</div>
						<h3 class="text-xl font-bold text-[#161616] mb-3">Analytics Pipelines</h3>
						<p class="text-[#444] mb-4">Building data pipelines using ClickHouse and event batching to track student engagement, completion rates, and drop-off points in real-time.</p>
                        <ul class="text-sm text-[#444] space-y-2">
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div> ClickHouse Data Warehousing</li>
                            <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-amber-500"></div> Real-time Event Batching</li>
                        </ul>
					</div>
				</div>
			</div>
		</section>

		{/* PROCESS FLOW OVERRIDE */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-white overflow-hidden">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16 gsap-reveal">
					<h2 class="text-3xl md:text-4xl font-display text-[#161616] mb-4">Engineering <span class="text-amber-600">Reliability</span></h2>
					<p class="text-[#444] max-w-2xl mx-auto">In education, downtime means lost learning. We build for absolute resilience.</p>
				</div>
				<AnimatedProcessFlow client:visible />
			</div>
		</section>

		{/* CTA */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-[#161616] text-white">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-4xl md:text-5xl font-display mb-6">Stop fighting your infrastructure.</h2>
				<p class="text-xl text-zinc-400 mb-10">Let's discuss how we can scale your EdTech platform.</p>
				<a href="/contact" class="inline-block px-10 py-4 bg-white text-[#161616] rounded-full font-bold hover:bg-amber-50 transition-colors">
					Talk to an engineer
				</a>
			</div>
		</section>
	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: {
				trigger: el,
				start: 'top 85%',
			},
			y: 30,
			opacity: 0,
			duration: 0.8,
			ease: 'power3.out'
		});
	});
</script>
