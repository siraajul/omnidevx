---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import { jobs } from "../../data/jobs";
import { MapPin, DollarSign, Calendar, Briefcase, CheckCircle2, UploadCloud, Send } from "lucide-react";

export function getStaticPaths() {
  return jobs.map(job => ({
    params: { slug: job.slug },
    props: { job }
  }));
}

const { job } = Astro.props;

// Map the department to a specific OG image (e.g. /og/jobs-engineering.png)
const departmentOgImage = `/og/jobs-${job.department.toLowerCase()}.png`;
---

<Layout 
	title={`${job.title} | Omnidevx Careers`} 
	description={job.description}
	ctaType="careers"
	ogImage={departmentOgImage}
>
	<main class="relative w-full min-h-screen bg-[#FDFCF7] pt-32 pb-24 px-8">
		<div class="max-w-7xl mx-auto">
            
            {/* Back Button */}
            <a href="/careers" class="inline-flex items-center gap-2 text-[#444] hover:text-[#2A6FDB] transition-colors font-medium mb-12 group">
                <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Back to Careers
            </a>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                
                {/* LEFT COLUMN: JOB DETAILS */}
                <div class="lg:col-span-7">
                    {/* Header */}
                    <div class="mb-12">
                        <span class="inline-block px-3 py-1 rounded-full bg-[#e8f0fd] text-[#2A6FDB] text-sm font-hand mb-4">
                            {job.department}
                        </span>
                        <h1 class="text-4xl md:text-5xl font-display text-[#161616] mb-6 tracking-tight leading-tight">
                            {job.title}
                        </h1>
                        <p class="text-xl text-[#444] leading-relaxed mb-8">
                            {job.description}
                        </p>

                        {/* Chips / Meta Info */}
                        <div class="flex flex-wrap gap-4">
                            <div class="flex items-center gap-2 px-4 py-2 bg-white border border-[#e8e5db] rounded-full text-zinc-700 font-medium shadow-sm">
                                <Briefcase className="w-4 h-4 text-[#2A6FDB]" strokeWidth={2.5} />
                                {job.type}
                            </div>
                            <div class="flex items-center gap-2 px-4 py-2 bg-white border border-[#e8e5db] rounded-full text-zinc-700 font-medium shadow-sm">
                                <MapPin className="w-4 h-4 text-rose-500" strokeWidth={2.5} />
                                {job.location}
                            </div>
                            <div class="flex items-center gap-2 px-4 py-2 bg-white border border-[#e8e5db] rounded-full text-zinc-700 font-medium shadow-sm">
                                <DollarSign className="w-4 h-4 text-green-600" strokeWidth={2.5} />
                                {job.salary}
                            </div>
                            <div class="flex items-center gap-2 px-4 py-2 bg-white border border-[#e8e5db] rounded-full text-zinc-700 font-medium shadow-sm">
                                <Calendar className="w-4 h-4 text-orange-500" strokeWidth={2.5} />
                                Apply by {job.deadline}
                            </div>
                        </div>
                    </div>

                    <hr class="border-[#e8e5db] mb-12" />

                    {/* Content Sections */}
                    <div class="space-y-12 text-zinc-700">
                        
                        <section>
                            <h2 class="text-2xl font-display text-[#161616] mb-6 tracking-tight">Roles & Responsibilities</h2>
                            <ul class="space-y-4">
                                {job.roles.map(role => (
                                    <li class="flex items-start gap-3">
                                        <div class="mt-1 flex-shrink-0">
                                            <div class="w-2 h-2 rounded-full bg-[#111]"></div>
                                        </div>
                                        <span class="leading-relaxed">{role}</span>
                                    </li>
                                ))}
                            </ul>
                        </section>

                        <section>
                            <h2 class="text-2xl font-display text-[#161616] mb-6 tracking-tight">Required Skills</h2>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                {job.skills.map(skill => (
                                    <div class="flex items-start gap-3 p-4 bg-white border border-[#e8e5db] rounded-2xl shadow-sm">
                                        <CheckCircle2 className="w-5 h-5 text-[#2A6FDB] shrink-0" strokeWidth={2.5} />
                                        <span class="font-medium text-[#161616] leading-snug">{skill}</span>
                                    </div>
                                ))}
                            </div>
                        </section>

                        <section>
                            <h2 class="text-2xl font-display text-[#161616] mb-6 tracking-tight">Education</h2>
                            <div class="p-6 bg-[#e8f0fd]/50 border border-blue-100 rounded-2xl text-blue-900 font-medium">
                                {job.education}
                            </div>
                        </section>

                        <section>
                            <h2 class="text-2xl font-display text-[#161616] mb-6 tracking-tight">Benefits & Perks</h2>
                            <ul class="space-y-4">
                                {job.benefits.map(benefit => (
                                    <li class="flex items-center gap-3">
                                        <div class="w-6 h-6 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                                            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                        </div>
                                        <span class="font-medium text-[#161616]">{benefit}</span>
                                    </li>
                                ))}
                            </ul>
                        </section>

                    </div>
                </div>

                {/* RIGHT COLUMN: APPLICATION FORM (STICKY) */}
                <div class="lg:col-span-5 lg:sticky lg:top-32">
                    <div class="bg-white border border-[#e8e5db] rounded-[2rem] p-8 shadow-xl shadow-zinc-200/50 relative overflow-hidden">
                        {/* Decorative Top Accent */}
                        <div class="absolute top-0 left-0 right-0 h-2 bg-[#111]"></div>

                        <div class="mb-8">
                            <h3 class="text-2xl font-display text-[#161616] mb-2">Apply Now</h3>
                            <p class="text-sm text-[#444] font-medium">Submit your application for {job.title}</p>
                        </div>

                        <form class="space-y-5" onsubmit="event.preventDefault();">
                            {/* Full Name */}
                            <div>
                                <label for="name" class="block text-xs font-bold text-[#161616] uppercase tracking-widest mb-2">Full Name</label>
                                <input type="text" id="name" placeholder="Jane Doe" class="w-full px-4 py-3 bg-[#f5f3ea] border border-[#e8e5db] rounded-xl focus:ring-2 focus:ring-[#2A6FDB] focus:border-transparent outline-none transition-all font-medium placeholder:text-[#444]" required />
                            </div>

                            {/* Email & Phone */}
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label for="email" class="block text-xs font-bold text-[#161616] uppercase tracking-widest mb-2">Email</label>
                                    <input type="email" id="email" placeholder="jane@example.com" class="w-full px-4 py-3 bg-[#f5f3ea] border border-[#e8e5db] rounded-xl focus:ring-2 focus:ring-[#2A6FDB] focus:border-transparent outline-none transition-all font-medium placeholder:text-[#444]" required />
                                </div>
                                <div>
                                    <label for="phone" class="block text-xs font-bold text-[#161616] uppercase tracking-widest mb-2">Phone</label>
                                    <input type="tel" id="phone" placeholder="(555) 000-0000" class="w-full px-4 py-3 bg-[#f5f3ea] border border-[#e8e5db] rounded-xl focus:ring-2 focus:ring-[#2A6FDB] focus:border-transparent outline-none transition-all font-medium placeholder:text-[#444]" />
                                </div>
                            </div>

                            {/* Cover Letter */}
                            <div>
                                <label for="coverletter" class="block text-xs font-bold text-[#161616] uppercase tracking-widest mb-2">Cover Letter</label>
                                <textarea id="coverletter" rows="4" placeholder="Tell us why you're a great fit..." class="w-full px-4 py-3 bg-[#f5f3ea] border border-[#e8e5db] rounded-xl focus:ring-2 focus:ring-[#2A6FDB] focus:border-transparent outline-none transition-all font-medium placeholder:text-[#444] resize-none" required></textarea>
                            </div>

                            {/* Why Hire You */}
                            <div>
                                <label for="why_hire" class="block text-xs font-bold text-[#161616] uppercase tracking-widest mb-2">Top 3 reasons we should hire you</label>
                                <textarea id="why_hire" rows="3" placeholder="1. ...&#10;2. ...&#10;3. ..." class="w-full px-4 py-3 bg-[#f5f3ea] border border-[#e8e5db] rounded-xl focus:ring-2 focus:ring-[#2A6FDB] focus:border-transparent outline-none transition-all font-medium placeholder:text-[#444] resize-none" required></textarea>
                            </div>

                            {/* Strengths & Weaknesses */}
                            <div>
                                <label for="strength" class="block text-xs font-bold text-[#161616] uppercase tracking-widest mb-2">Your Greatest Strength</label>
                                <textarea id="strength" rows="2" placeholder="e.g. System Architecture, Problem-solving..." class="w-full px-4 py-3 bg-[#f5f3ea] border border-[#e8e5db] rounded-xl focus:ring-2 focus:ring-[#2A6FDB] focus:border-transparent outline-none transition-all font-medium placeholder:text-[#444] resize-none" required></textarea>
                            </div>
                            
                            <div>
                                <label for="weakness" class="block text-xs font-bold text-[#161616] uppercase tracking-widest mb-2">Your Greatest Weakness</label>
                                <textarea id="weakness" rows="2" placeholder="e.g. Delegating tasks, Public speaking..." class="w-full px-4 py-3 bg-[#f5f3ea] border border-[#e8e5db] rounded-xl focus:ring-2 focus:ring-[#2A6FDB] focus:border-transparent outline-none transition-all font-medium placeholder:text-[#444] resize-none" required></textarea>
                            </div>

                            {/* Resume Upload Dropzone */}
                            <div>
                                <label class="block text-xs font-bold text-[#161616] uppercase tracking-widest mb-2">Resume / CV</label>
                                <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-zinc-300 border-dashed rounded-xl cursor-pointer bg-[#f5f3ea] hover:bg-[#f5f3ea] hover:border-[#2A6FDB] transition-colors group">
                                    <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                        <UploadCloud className="w-8 h-8 text-[#444] group-hover:text-[#2A6FDB] mb-3 transition-colors" />
                                        <p class="mb-1 text-sm text-[#2A2A2A] font-medium"><span class="font-bold text-[#2A6FDB]">Click to upload</span> or drag and drop</p>
                                        <p class="text-xs text-[#444] font-medium">PDF, DOCX, or RTF (Max 5MB)</p>
                                    </div>
                                    <input type="file" class="hidden" accept=".pdf,.doc,.docx,.rtf" />
                                </label>
                            </div>

                            {/* Submit Button */}
                            <button type="submit" class="w-full group relative inline-flex items-center justify-center px-8 py-4 bg-[#111] text-white font-hand text-sm rounded-xl overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(37,99,235,0.4)] mt-4">
                                <div class="absolute inset-0 bg-blue-700 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                                <span class="relative flex items-center gap-2">
                                    Submit Application
                                    <Send className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" />
                                </span>
                            </button>
                        </form>
                    </div>
                </div>

            </div>
		</div>
	</main>
</Layout>
