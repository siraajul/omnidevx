---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio | Omnidevx" ogImage="/og/portfolio.png" description="Case studies and selected works from our partnerships with startups and enterprise clients.">
	<main class="relative w-full pt-32 pb-16 px-8">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-16">
				<h1 class="text-4xl md:text-5xl font-display text-[#161616] mb-6">
					Our <span class="scribble-underline text-[#2A6FDB]">Portfolio</span>
				</h1>
				<p class="text-xl text-[#444] max-w-2xl mx-auto">
					Code we've actually shipped. No vaporware, just real products solving hard problems.
				</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<!-- PayLab Pro -->
				<a href="/portfolio/paylab-pro" class="group relative aspect-[4/3] rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-shadow">
					<div class="absolute inset-0 bg-gradient-to-br from-[#2A6FDB] to-indigo-700">
						<div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:40px_40px]"></div>
					</div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent z-10"></div>
					<div class="absolute bottom-0 left-0 p-8 z-20">
						<span class="px-3 py-1 bg-white/20 text-white text-xs font-bold rounded-full backdrop-blur-sm mb-3 inline-block tracking-wider uppercase">FinTech</span>
						<h3 class="text-3xl font-bold text-white mb-2 group-hover:text-blue-300 transition-colors">PayLab Pro</h3>
						<p class="text-white/70">A billing engine that doesn't fall over.</p>
					</div>
					<div class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity z-20 border border-white/30">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
					</div>
				</a>

				<!-- NexusAI -->
				<a href="/portfolio/nexusai" class="group relative aspect-[4/3] rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-shadow">
					<div class="absolute inset-0 bg-gradient-to-br from-purple-600 to-pink-600">
						<div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:40px_40px]"></div>
					</div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent z-10"></div>
					<div class="absolute bottom-0 left-0 p-8 z-20">
						<span class="px-3 py-1 bg-white/20 text-white text-xs font-bold rounded-full backdrop-blur-sm mb-3 inline-block tracking-wider uppercase">AI / ML</span>
						<h3 class="text-3xl font-bold text-white mb-2 group-hover:text-purple-300 transition-colors">NexusAI</h3>
						<p class="text-white/70">LLMs extracting data from messy PDFs at scale.</p>
					</div>
					<div class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity z-20 border border-white/30">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
					</div>
				</a>

				<!-- FieldSync -->
				<a href="/portfolio/fieldsync" class="group relative aspect-[4/3] rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-shadow">
					<div class="absolute inset-0 bg-gradient-to-br from-emerald-500 to-teal-600">
						<div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:40px_40px]"></div>
					</div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent z-10"></div>
					<div class="absolute bottom-0 left-0 p-8 z-20">
						<span class="px-3 py-1 bg-white/20 text-white text-xs font-bold rounded-full backdrop-blur-sm mb-3 inline-block tracking-wider uppercase">SaaS</span>
						<h3 class="text-3xl font-bold text-white mb-2 group-hover:text-emerald-300 transition-colors">FieldSync</h3>
						<p class="text-white/70">Offline-first sync for teams in the mud.</p>
					</div>
					<div class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity z-20 border border-white/30">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
					</div>
				</a>

				<!-- CTA Card -->
				<div class="group relative aspect-[4/3] rounded-3xl overflow-hidden border-2 border-dashed border-[#e8e5db] flex flex-col items-center justify-center text-center p-8 hover:border-[#2A6FDB] transition-colors">
					<h3 class="text-2xl font-display text-[#161616] mb-3">Your Project Here</h3>
					<p class="text-[#444] mb-6 max-w-xs">Stop reading case studies and let's get to work.</p>
					<a href="/contact" class="px-6 py-3 bg-[#111] text-white font-hand rounded-full hover:bg-[#2A6FDB] transition-colors text-sm">
						talk to an engineer →
					</a>
				</div>
			</div>
		</div>
	</main>
</Layout>
