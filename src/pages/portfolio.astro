---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="relative w-full min-h-screen bg-black pt-32 pb-16 px-8">
		<div class="max-w-7xl mx-auto">
			<h1 class="text-5xl md:text-7xl font-black text-indigo-600 mb-6">
				Our Portfolio
			</h1>
			<p class="text-xl text-zinc-400 max-w-2xl mb-16">
				Case studies and selected works from our partnerships with startups and enterprise clients.
			</p>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{/* Portfolio Cards Placeholder */}
				<div class="group relative aspect-[4/3] bg-zinc-900 rounded-3xl overflow-hidden border border-zinc-800">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent z-10"></div>
					<div class="absolute bottom-0 left-0 p-8 z-20">
                        <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 text-sm font-semibold rounded-full mb-3 inline-block">FinTech</span>
                        <h3 class="text-3xl font-bold text-white mb-2 group-hover:text-indigo-400 transition-colors">PayLab Pro Ecosystem</h3>
                        <p class="text-zinc-300">Modernizing contractor financial tools.</p>
                    </div>
				</div>
                <div class="group relative aspect-[4/3] bg-zinc-900 rounded-3xl overflow-hidden border border-zinc-800">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent z-10"></div>
					<div class="absolute bottom-0 left-0 p-8 z-20">
                        <span class="px-3 py-1 bg-purple-500/20 text-purple-300 text-sm font-semibold rounded-full mb-3 inline-block">SaaS</span>
                        <h3 class="text-3xl font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">AI Cost Estimator</h3>
                        <p class="text-zinc-300">Intelligent project quoting system.</p>
                    </div>
				</div>
			</div>
		</div>
	</main>
</Layout>
