---
import Layout from '../../layouts/Layout.astro';
import { ContainerScroll } from '../../components/ui/container-scroll-animation';
import { WebDevDashboard } from '../../components/ui/dashboards/WebDevDashboard';
import { WebFeatures } from '../../components/ui/feature-wrappers';
import { AnimatedProcessFlow } from '../../components/ui/animated-process-flow';
---

<Layout ogImage="/og/services-web.png">
	<main class="relative w-full overflow-hidden bg-white">
		
		{/* HERO SECTION */}
		<div class="flex flex-col overflow-hidden pt-20 pb-10 md:pt-32 md:pb-20">
			<ContainerScroll client:load>
				<div slot="titleComponent">
					<h1 class="text-4xl md:text-5xl font-semibold text-zinc-900 mb-8">
						Enterprise <br />
						<span class="text-5xl md:text-[6rem] font-black mt-2 leading-none text-blue-600 block">
							Web Applications
						</span>
					</h1>
				</div>
				<WebDevDashboard />
			</ContainerScroll>
		</div>

		{/* CORE COMPETENCIES */}
		<section class="py-16 border-t border-zinc-200 bg-zinc-50">
			<div class="max-w-6xl mx-auto px-8 text-center mb-8">
				<h2 class="text-3xl md:text-4xl font-black text-zinc-900 mb-4 tracking-tight">Core <span class="text-blue-600">Competencies</span></h2>
				<p class="text-zinc-500 max-w-xl mx-auto">Enterprise-grade web engineering that scales.</p>
			</div>
			<WebFeatures client:visible />
		</section>

		{/* SOCIAL PROOF */}
		<section class="py-12 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto">
				<a href="/portfolio/paylab-pro" class="group flex flex-col md:flex-row items-center gap-6 p-6 rounded-2xl border border-zinc-200 bg-zinc-50 hover:border-zinc-300 transition-colors">
					<div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-700 flex-shrink-0 flex items-center justify-center">
						<span class="text-zinc-900 font-black text-lg">PL</span>
					</div>
					<div class="flex-1 text-center md:text-left">
						<p class="text-xs font-bold text-zinc-500 uppercase tracking-widest mb-1">Case Study</p>
						<h3 class="text-lg font-bold text-zinc-900 group-hover:text-blue-600 transition-colors">PayLab Pro — 3x faster invoicing, 40% cost reduction</h3>
					</div>
					<span class="text-zinc-500 group-hover:text-zinc-900 transition-colors text-sm font-medium flex items-center gap-1 flex-shrink-0">Read story <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
				</a>
			</div>
		</section>

		{/* HOW WE APPROACH IT */}
		<section class="py-24 px-8 border-t border-zinc-200 bg-zinc-50">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl font-bold text-zinc-900 mb-16 text-center gsap-reveal">Our Engineering Process</h2>
				<AnimatedProcessFlow type="web" client:visible />
			</div>
		</section>

		{/* TECH STACK */}
		<section class="py-24 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-3xl font-bold text-zinc-900 mb-6">The Modern Web Stack</h2>
				<p class="text-zinc-500 mb-12">We use the most reliable, modern frameworks to ensure your application stands the test of time.</p>
				
				<div class="flex flex-wrap justify-center gap-4">
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/react/61DAFB" class="w-5 h-5" alt="React" /> React 19
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/nextdotjs/09090b" class="w-5 h-5" alt="Next.js" /> Next.js
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/typescript/3178C6" class="w-5 h-5" alt="TypeScript" /> TypeScript
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/tailwindcss/38B2AC" class="w-5 h-5" alt="Tailwind CSS" /> Tailwind CSS
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/prisma/09090b" class="w-5 h-5" alt="Prisma" /> Prisma ORM
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/postgresql/4169E1" class="w-5 h-5" alt="PostgreSQL" /> PostgreSQL
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/nodedotjs/339933" class="w-5 h-5" alt="Node.js" /> Node.js
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/graphql/E10098" class="w-5 h-5" alt="GraphQL" /> GraphQL
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/radixui/09090b" class="w-5 h-5" alt="Radix UI" /> Radix UI
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/framer/0055FF" class="w-5 h-5" alt="Framer Motion" /> Framer Motion
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/vercel/09090b" class="w-5 h-5" alt="Vercel" /> Vercel
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/supabase/3ECF8E" class="w-5 h-5" alt="Supabase" /> Supabase
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/stripe/008CDD" class="w-5 h-5" alt="Stripe" /> Stripe
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/figma/F24E1E" class="w-5 h-5" alt="Figma" /> Figma
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/vitest/6E9F18" class="w-5 h-5" alt="Vitest" /> Vitest
					</span>
				</div>
			</div>
		</section>



		{/* TESTIMONIALS */}
		<section class="py-24 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<svg class="w-12 h-12 text-blue-500 mx-auto mb-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
				<p class="text-2xl md:text-3xl font-medium text-zinc-900 mb-8 leading-relaxed">
					"The attention to detail regarding frontend performance and accessibility was unmatched. Our web app now scores 100 on Lighthouse across the board."
				</p>
				<div>
					<p class="font-bold text-zinc-900">Elena Rodriguez</p>
					<p class="text-zinc-500 text-sm">VP of Engineering, TechCorp</p>
				</div>
			</div>
		</section>



		{/* CTA */}
		<section class="py-24 px-8 border-t border-zinc-200 text-center">
			<div class="max-w-2xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-black text-zinc-900 mb-4 tracking-tight">Ready to build your <span class="text-blue-600">platform</span>?</h2>
				<p class="text-zinc-500 mb-8">Let's architect something that scales with your ambition.</p>
				<a href="/contact" class="inline-flex items-center gap-2 px-10 py-5 bg-blue-600 hover:bg-blue-500 text-zinc-900 font-bold rounded-full transition-colors text-lg">
					Book a Call →
				</a>
			</div>
		</section>

	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: { trigger: el, start: 'top 85%' },
			y: 40, opacity: 0, duration: 0.8, ease: 'power3.out'
		});
	});
</script>
