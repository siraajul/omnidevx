---
import Layout from '../../layouts/Layout.astro';
import { ContainerScroll } from '../../components/sections/container-scroll-animation';
import { MobileDevDashboard } from '../../components/ui/dashboards/MobileDevDashboard';
import { MobileFeatures } from '../../components/ui/feature-wrappers';
import { AnimatedProcessFlow } from '../../components/sections/animated-process-flow';
---

<Layout ogImage="/og/services-mobile.png">
	<main class="relative w-full overflow-hidden bg-white">
		
		{/* HERO SECTION */}
		<div class="flex flex-col overflow-hidden pt-20 pb-10 md:pt-32 md:pb-20">
			<ContainerScroll client:load>
				<div slot="titleComponent">
					<h1 class="text-4xl md:text-5xl font-semibold text-[#161616] mb-8">
						Native-Feeling <br />
						<span class="text-5xl md:text-[6rem] font-black mt-2 leading-none text-green-600 block">
							Mobile Apps
						</span>
					</h1>
				</div>
				<MobileDevDashboard />
			</ContainerScroll>
		</div>

		{/* CORE COMPETENCIES */}
		<section class="py-16 border-t border-[#e8e5db] bg-[#f5f3ea]">
			<div class="max-w-6xl mx-auto px-8 text-center mb-8">
				<h2 class="text-3xl md:text-4xl font-display text-[#161616] mb-4 tracking-tight">Core <span class="text-green-600">Competencies</span></h2>
				<p class="text-[#444] max-w-xl mx-auto">What makes our mobile apps stand apart.</p>
			</div>
			<MobileFeatures client:visible />
		</section>

		{/* SOCIAL PROOF — COMPACT CASE STUDY */}
		<section class="py-12 px-8 border-t border-[#e8e5db]">
			<div class="max-w-4xl mx-auto">
				<a href="/portfolio/fieldsync" class="group flex flex-col md:flex-row items-center gap-6 p-6 rounded-2xl border border-[#e8e5db] bg-[#f5f3ea] hover:border-zinc-300 transition-colors">
					<div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex-shrink-0 flex items-center justify-center">
						<span class="text-[#161616] font-black text-lg">FS</span>
					</div>
					<div class="flex-1 text-center md:text-left">
						<p class="text-xs font-bold text-[#444] uppercase tracking-widest mb-1">Case Study</p>
						<h3 class="text-lg font-bold text-[#161616] group-hover:text-emerald-600 transition-colors">FieldSync — 50% faster response for 400+ field techs</h3>
					</div>
					<span class="text-[#444] group-hover:text-[#161616] transition-colors text-sm font-medium flex items-center gap-1 flex-shrink-0">Read story <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
				</a>
			</div>
		</section>

		{/* HOW WE APPROACH IT */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-[#f5f3ea]">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl font-bold text-[#161616] mb-16 text-center gsap-reveal">Our Mobile Approach</h2>
				<AnimatedProcessFlow type="mobile" client:visible />
			</div>
		</section>

		{/* TECH STACK */}
		<section class="py-24 px-8 border-t border-[#e8e5db]">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-3xl font-bold text-[#161616] mb-6">The Mobile Stack</h2>
				<p class="text-[#444] mb-12">Industry-standard tools for shipping reliable applications to millions of devices.</p>
				
				<div class="flex flex-wrap justify-center gap-4">
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/react/61DAFB" class="w-5 h-5" alt="React Native" /> React Native
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/expo/09090b" class="w-5 h-5" alt="Expo" /> Expo
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/swift/F05138" class="w-5 h-5" alt="Swift" /> Swift
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/kotlin/7F52FF" class="w-5 h-5" alt="Kotlin" /> Kotlin
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/nodedotjs/339933" class="w-5 h-5" alt="Zustand" /> Zustand
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/sentry/362D59" class="w-5 h-5" alt="Sentry" /> Sentry (Crashlytics)
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/android/3DDC84" class="w-5 h-5" alt="Android" /> Android
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/apple/09090b" class="w-5 h-5" alt="iOS" /> Apple iOS
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/firebase/FFCA28" class="w-5 h-5" alt="Firebase" /> Firebase
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/sqlite/003B57" class="w-5 h-5" alt="SQLite" /> SQLite
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/fastlane/00F200" class="w-5 h-5" alt="Fastlane" /> Fastlane
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/jest/C21325" class="w-5 h-5" alt="Jest" /> Jest
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/stripe/008CDD" class="w-5 h-5" alt="Stripe" /> Stripe Connect
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/tailwindcss/38B2AC" class="w-5 h-5" alt="Tailwind CSS" /> NativeWind
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/githubactions/2088FF" class="w-5 h-5" alt="GitHub Actions" /> CI/CD
					</span>
				</div>
			</div>
		</section>



		{/* TESTIMONIALS */}
		<section class="py-24 px-8 border-t border-[#e8e5db]">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<svg class="w-12 h-12 text-green-500 mx-auto mb-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
				<p class="text-2xl md:text-3xl font-medium text-[#161616] mb-8 leading-relaxed">
					"We thought we needed two separate teams for iOS and Android. omnidevx delivered both simultaneously using React Native, saving us massive amounts of capital."
				</p>
				<div>
					<p class="font-bold text-[#161616]">Michael Chang</p>
					<p class="text-[#444] text-sm">CEO, FitPulse</p>
				</div>
			</div>
		</section>



		{/* CTA */}
		<section class="py-24 px-8 border-t border-[#e8e5db] text-center">
			<div class="max-w-2xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-display text-[#161616] mb-4 tracking-tight">Ready to build your <span class="text-green-600">app</span>?</h2>
				<p class="text-[#444] mb-8">Let's discuss your project and ship something users love.</p>
				<a href="/contact" class="inline-flex items-center gap-2 px-10 py-5 bg-green-600 hover:bg-green-500 text-[#161616] font-bold rounded-full transition-colors text-lg">
					Book a Call →
				</a>
			</div>
		</section>

	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: { trigger: el, start: 'top 85%' },
			y: 40, opacity: 0, duration: 0.8, ease: 'power3.out'
		});
	});
</script>
