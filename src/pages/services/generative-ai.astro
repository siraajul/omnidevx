---
import Layout from '../../layouts/Layout.astro';
import { ContainerScroll } from '../../components/sections/container-scroll-animation';
import { GenAiDashboard } from '../../components/ui/dashboards/GenAiDashboard';
import { GenAiFeatures } from '../../components/ui/feature-wrappers';
import { AnimatedProcessFlow } from '../../components/sections/animated-process-flow';
---

<Layout ogImage="/og/services-genai.png">
	<main class="relative w-full overflow-hidden bg-white">
		
		{/* HERO SECTION */}
		<div class="flex flex-col overflow-hidden pt-20 pb-10 md:pt-32 md:pb-20">
			<ContainerScroll client:load>
				<div slot="titleComponent">
					<h1 class="text-4xl md:text-5xl font-semibold text-[#161616] mb-8">
						<span class="text-purple-600 font-black">Generative AI</span> Integration <br />
						<span class="text-xl md:text-2xl font-normal mt-4 block text-[#444] max-w-2xl mx-auto">
							Embed intelligent automation directly into your products using advanced LLMs and custom RAG pipelines.
						</span>
					</h1>
				</div>
				<GenAiDashboard />
			</ContainerScroll>
		</div>

		{/* CORE COMPETENCIES */}
		<section class="py-16 border-t border-[#e8e5db] bg-[#f5f3ea]">
			<div class="max-w-6xl mx-auto px-8 text-center mb-8">
				<h2 class="text-3xl md:text-4xl font-display text-[#161616] mb-4 tracking-tight">Core <span class="text-cyan-600">Competencies</span></h2>
				<p class="text-[#444] max-w-xl mx-auto">Production-ready generative AI at scale.</p>
			</div>
			<GenAiFeatures client:visible />
		</section>

		{/* SOCIAL PROOF */}
		<section class="py-12 px-8 border-t border-[#e8e5db]">
			<div class="max-w-4xl mx-auto">
				<a href="/portfolio/nexusai" class="group flex flex-col md:flex-row items-center gap-6 p-6 rounded-2xl border border-[#e8e5db] bg-[#f5f3ea] hover:border-zinc-300 transition-colors">
					<div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-600 to-pink-600 flex-shrink-0 flex items-center justify-center">
						<span class="text-[#161616] font-black text-lg">NX</span>
					</div>
					<div class="flex-1 text-center md:text-left">
						<p class="text-xs font-bold text-[#444] uppercase tracking-widest mb-1">Case Study</p>
						<h3 class="text-lg font-bold text-[#161616] group-hover:text-cyan-600 transition-colors">NexusAI — 95% accuracy across 12M enterprise documents</h3>
					</div>
					<span class="text-[#444] group-hover:text-[#161616] transition-colors text-sm font-medium flex items-center gap-1 flex-shrink-0">Read story <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
				</a>
			</div>
		</section>

		{/* HOW WE APPROACH IT */}
		<section class="py-24 px-8 border-t border-[#e8e5db] bg-[#f5f3ea]">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl font-bold text-[#161616] mb-16 text-center gsap-reveal">How we approach AI Integration</h2>
				<AnimatedProcessFlow type="genai" client:visible />
			</div>
		</section>

		{/* TECH STACK */}
		<section class="py-24 px-8 border-t border-[#e8e5db]">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-3xl font-bold text-[#161616] mb-6">The Intelligence Stack</h2>
				<p class="text-[#444] mb-12">The industry-leading AI models and vector databases we use to build cognitive features.</p>
				
				<div class="flex flex-wrap justify-center gap-4">
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/openai/09090b" class="w-5 h-5" alt="OpenAI" /> OpenAI GPT-4
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/anthropic/D97757" class="w-5 h-5" alt="Anthropic Claude" /> Anthropic Claude
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/meta/0467DF" class="w-5 h-5" alt="Meta Llama" /> Llama 3
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/huggingface/FFD21E" class="w-5 h-5" alt="Hugging Face" /> Hugging Face
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/mongodb/47A248" class="w-5 h-5" alt="MongoDB" /> MongoDB
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/elasticsearch/005571" class="w-5 h-5" alt="Elasticsearch" /> Elasticsearch
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/supabase/3ECF8E" class="w-5 h-5" alt="Supabase" /> Supabase
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/langchain/09090b" class="w-5 h-5" alt="LangChain" /> LangChain
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/vercel/09090b" class="w-5 h-5" alt="Vercel AI SDK" /> Vercel AI SDK
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/python/3776AB" class="w-5 h-5" alt="Python" /> Python
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/pytorch/EE4C2C" class="w-5 h-5" alt="PyTorch" /> PyTorch
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/tensorflow/FF6F00" class="w-5 h-5" alt="TensorFlow" /> TensorFlow
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/fastapi/009688" class="w-5 h-5" alt="FastAPI" /> FastAPI
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/redis/FF4438" class="w-5 h-5" alt="Redis" /> Redis
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-[#e8e5db] text-[#161616] rounded-full font-medium">
						<img width="20" height="20" loading="lazy" decoding="async" src="https://cdn.simpleicons.org/googlecloud/4285F4" class="w-5 h-5" alt="Google Cloud" /> Google Cloud
					</span>
				</div>
			</div>
		</section>



		{/* TESTIMONIALS */}
		<section class="py-24 px-8 border-t border-[#e8e5db]">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<svg class="w-12 h-12 text-purple-500 mx-auto mb-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
				<p class="text-2xl md:text-3xl font-medium text-[#161616] mb-8 leading-relaxed">
					"Integrating LLMs seemed like a monumental task, but the team at omnidevx built a custom vector database and search interface that completely revolutionized our product."
				</p>
				<div>
					<p class="font-bold text-[#161616]">David Chen</p>
					<p class="text-[#444] text-sm">CTO, Nexus Data</p>
				</div>
			</div>
		</section>



		{/* CTA */}
		<section class="py-24 px-8 border-t border-[#e8e5db] text-center">
			<div class="max-w-2xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-display text-[#161616] mb-4 tracking-tight">Ready to harness <span class="text-cyan-600">Generative AI</span>?</h2>
				<p class="text-[#444] mb-8">Let's build intelligent systems that transform your business.</p>
				<a href="/contact" class="inline-flex items-center gap-2 px-10 py-5 bg-cyan-600 hover:bg-cyan-500 text-[#161616] font-bold rounded-full transition-colors text-lg">
					Book a Call →
				</a>
			</div>
		</section>

	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: { trigger: el, start: 'top 85%' },
			y: 40, opacity: 0, duration: 0.8, ease: 'power3.out'
		});
	});
</script>
