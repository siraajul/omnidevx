---
import Layout from '../../layouts/Layout.astro';
import { ContainerScroll } from '../../components/sections/container-scroll-animation';
import { AiMvpDashboard } from '../../components/ui/dashboards/AiMvpDashboard';
import { AiFeatures } from '../../components/ui/feature-wrappers';
import { AnimatedProcessFlow } from '../../components/sections/animated-process-flow';
---

<Layout ogImage="/og/services-mvp.png">
	<main class="relative w-full overflow-hidden bg-white">
		
		{/* HERO SECTION */}
		<div class="flex flex-col overflow-hidden pt-20 pb-10 md:pt-32 md:pb-20">
			<ContainerScroll client:load>
				<div slot="titleComponent">
					<h1 class="text-4xl md:text-5xl font-semibold text-zinc-900 mb-8">
						Accelerate to market with <br />
						<span class="text-5xl md:text-[6rem] font-black mt-2 leading-none text-indigo-500">
							AI MVP Engineering
						</span>
					</h1>
				</div>
				<AiMvpDashboard />
			</ContainerScroll>
		</div>

		{/* CORE COMPETENCIES */}
		<section class="py-16 border-t border-zinc-200 bg-zinc-50">
			<div class="max-w-6xl mx-auto px-8 text-center mb-8">
				<h2 class="text-3xl md:text-4xl font-black text-zinc-900 mb-4 tracking-tight">Core <span class="text-purple-600">Competencies</span></h2>
				<p class="text-zinc-500 max-w-xl mx-auto">AI-first engineering for rapid market entry.</p>
			</div>
			<AiFeatures client:visible />
		</section>

		{/* SOCIAL PROOF */}
		<section class="py-12 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto">
				<a href="/portfolio/nexusai" class="group flex flex-col md:flex-row items-center gap-6 p-6 rounded-2xl border border-zinc-200 bg-zinc-50 hover:border-zinc-300 transition-colors">
					<div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-600 to-pink-600 flex-shrink-0 flex items-center justify-center">
						<span class="text-zinc-900 font-black text-lg">NX</span>
					</div>
					<div class="flex-1 text-center md:text-left">
						<p class="text-xs font-bold text-zinc-500 uppercase tracking-widest mb-1">Case Study</p>
						<h3 class="text-lg font-bold text-zinc-900 group-hover:text-purple-600 transition-colors">NexusAI — 95% accuracy across 12M enterprise documents</h3>
					</div>
					<span class="text-zinc-500 group-hover:text-zinc-900 transition-colors text-sm font-medium flex items-center gap-1 flex-shrink-0">Read story <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
				</a>
			</div>
		</section>

		{/* HOW WE APPROACH IT */}
		<section class="py-24 px-8 border-t border-zinc-200 bg-zinc-50">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl font-bold text-zinc-900 mb-16 text-center gsap-reveal">How we approach MVP Development</h2>
				<AnimatedProcessFlow type="ai" client:visible />
			</div>
		</section>

		{/* TECH STACK */}
		<section class="py-24 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-3xl font-bold text-zinc-900 mb-6">Built for Speed & Scale</h2>
				<p class="text-zinc-500 mb-12">The technologies we use to rapidly deploy your MVP without sacrificing future scalability.</p>
				
				<div class="flex flex-wrap justify-center gap-4">
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/astro/09090b" class="w-5 h-5" alt="Astro" /> Astro
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/nextdotjs/09090b" class="w-5 h-5" alt="Next.js" /> Next.js
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/react/61DAFB" class="w-5 h-5" alt="React" /> React
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/typescript/3178C6" class="w-5 h-5" alt="TypeScript" /> TypeScript
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/tailwindcss/38B2AC" class="w-5 h-5" alt="Tailwind" /> Tailwind CSS
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/supabase/3ECF8E" class="w-5 h-5" alt="Supabase" /> Supabase
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/postgresql/4169E1" class="w-5 h-5" alt="PostgreSQL" /> PostgreSQL
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/prisma/09090b" class="w-5 h-5" alt="Prisma" /> Prisma
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/redis/FF4438" class="w-5 h-5" alt="Redis" /> Redis
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/stripe/008CDD" class="w-5 h-5" alt="Stripe" /> Stripe
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/openai/09090b" class="w-5 h-5" alt="OpenAI" /> OpenAI
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/anthropic/D97757" class="w-5 h-5" alt="Anthropic" /> Anthropic
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/amazonwebservices.svg" class="w-5 h-5" alt="AWS" /> AWS
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/vercel/09090b" class="w-5 h-5" alt="Vercel" /> Vercel
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/github/09090b" class="w-5 h-5" alt="GitHub Copilot" /> GitHub Copilot
					</span>
				</div>
			</div>
		</section>



		{/* TESTIMONIALS */}
		<section class="py-24 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<svg class="w-12 h-12 text-indigo-500 mx-auto mb-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
				<p class="text-2xl md:text-3xl font-medium text-zinc-900 mb-8 leading-relaxed">
					"The speed at which omnidevx delivered our MVP was staggering. We were able to start onboarding beta users and pitching investors weeks ahead of schedule."
				</p>
				<div>
					<p class="font-bold text-zinc-900">Sarah Jenkins</p>
					<p class="text-zinc-500 text-sm">Founder, StartupX</p>
				</div>
			</div>
		</section>



		{/* CTA */}
		<section class="py-24 px-8 border-t border-zinc-200 text-center">
			<div class="max-w-2xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-black text-zinc-900 mb-4 tracking-tight">Ready to launch your <span class="text-purple-600">AI MVP</span>?</h2>
				<p class="text-zinc-500 mb-8">From concept to production in weeks, not months.</p>
				<a href="/contact" class="inline-flex items-center gap-2 px-10 py-5 bg-purple-600 hover:bg-purple-500 text-zinc-900 font-bold rounded-full transition-colors text-lg">
					Book a Call →
				</a>
			</div>
		</section>

	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: { trigger: el, start: 'top 85%' },
			y: 40, opacity: 0, duration: 0.8, ease: 'power3.out'
		});
	});
</script>
