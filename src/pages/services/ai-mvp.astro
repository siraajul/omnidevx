---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
	<main class="relative w-full overflow-hidden bg-black">
		
		{/* HERO SECTION */}
		<section class="min-h-[80vh] flex flex-col items-center justify-center px-8 relative pt-32 pb-16">
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-600/20 rounded-full blur-[100px] pointer-events-none"></div>

			<div class="relative z-10 max-w-4xl mx-auto text-center gsap-reveal">
				<span class="inline-block px-3 py-1 bg-indigo-500/20 text-indigo-300 text-sm font-bold rounded-full mb-6">Flagship Service</span>
				<h1 class="text-5xl md:text-7xl font-black text-white leading-tight mb-8">
					AI-Powered <span class="text-indigo-400">Fast MVP</span> Development
				</h1>
				<p class="text-xl text-zinc-400 max-w-2xl mx-auto mb-10">
					Stop spending months building a v1. We leverage advanced Generative AI coding tools and pre-built infrastructure to launch your Minimum Viable Product in weeks.
				</p>
			</div>
		</section>

		{/* HOW WE APPROACH IT */}
		<section class="py-24 px-8 border-t border-zinc-900 bg-zinc-950/30">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl font-bold text-white mb-16 text-center gsap-reveal">How we approach MVP Development</h2>
				
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div class="gsap-reveal p-6 bg-zinc-900 rounded-2xl border border-zinc-800">
						<div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 flex items-center justify-center rounded-xl mb-6 font-bold text-xl">1</div>
						<h3 class="text-xl font-bold text-white mb-3">Discovery & Scoping</h3>
						<p class="text-zinc-400 text-sm">We brutally cut scope to identify the core 20% of features that will deliver 80% of the value to your early adopters.</p>
					</div>
					<div class="gsap-reveal p-6 bg-zinc-900 rounded-2xl border border-zinc-800">
						<div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 flex items-center justify-center rounded-xl mb-6 font-bold text-xl">2</div>
						<h3 class="text-xl font-bold text-white mb-3">AI-Assisted Prototyping</h3>
						<p class="text-zinc-400 text-sm">Using AI generation, we instantly create high-fidelity UI/UX flows to validate the concept before writing a line of code.</p>
					</div>
					<div class="gsap-reveal p-6 bg-zinc-900 rounded-2xl border border-zinc-800">
						<div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 flex items-center justify-center rounded-xl mb-6 font-bold text-xl">3</div>
						<h3 class="text-xl font-bold text-white mb-3">Rapid Engineering</h3>
						<p class="text-zinc-400 text-sm">Our engineers pair with advanced AI models to write boilerplate and standard logic at 10x speed, focusing human effort on unique business logic.</p>
					</div>
					<div class="gsap-reveal p-6 bg-zinc-900 rounded-2xl border border-zinc-800">
						<div class="w-12 h-12 bg-indigo-500/20 text-indigo-400 flex items-center justify-center rounded-xl mb-6 font-bold text-xl">4</div>
						<h3 class="text-xl font-bold text-white mb-3">Launch & Iterate</h3>
						<p class="text-zinc-400 text-sm">We deploy to scalable cloud infrastructure (Vercel/AWS) and install analytics to capture immediate user feedback.</p>
					</div>
				</div>
			</div>
		</section>

		{/* TECH STACK */}
		<section class="py-24 px-8 border-t border-zinc-900">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-3xl font-bold text-white mb-6">Built for Speed & Scale</h2>
				<p class="text-zinc-400 mb-12">The technologies we use to rapidly deploy your MVP without sacrificing future scalability.</p>
				
				<div class="flex flex-wrap justify-center gap-4">
					<span class="flex items-center gap-2 px-6 py-3 bg-zinc-900 border border-zinc-800 text-white rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/astro/white" class="w-5 h-5" alt="Astro" /> Astro
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-zinc-900 border border-zinc-800 text-white rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/nextdotjs/white" class="w-5 h-5" alt="Next.js" /> Next.js
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-zinc-900 border border-zinc-800 text-white rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/tailwindcss/38B2AC" class="w-5 h-5" alt="Tailwind" /> Tailwind CSS
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-zinc-900 border border-zinc-800 text-white rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/supabase/3ECF8E" class="w-5 h-5" alt="Supabase" /> Supabase
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-zinc-900 border border-zinc-800 text-white rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/vercel/white" class="w-5 h-5" alt="Vercel" /> Vercel
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-zinc-900 border border-zinc-800 text-white rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/github/white" class="w-5 h-5" alt="GitHub Copilot" /> GitHub Copilot
					</span>
				</div>
			</div>
		</section>

		{/* CASE STUDIES */}
		<section class="py-24 px-8 border-t border-zinc-900 bg-zinc-950/30">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl font-bold text-white mb-12 gsap-reveal">MVP Case Studies</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<div class="gsap-reveal group relative aspect-video bg-zinc-900 rounded-3xl overflow-hidden border border-zinc-800">
						<div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent z-10"></div>
						<div class="absolute bottom-0 left-0 p-8 z-20">
							<h3 class="text-2xl font-bold text-white mb-2">FinTech Dashboard MVP</h3>
							<p class="text-zinc-300 text-sm mb-4">From idea to live beta in 21 days.</p>
							<a href="#" class="text-indigo-400 font-semibold group-hover:underline">Read Case Study &rarr;</a>
						</div>
					</div>
					<div class="gsap-reveal group relative aspect-video bg-zinc-900 rounded-3xl overflow-hidden border border-zinc-800">
						<div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent z-10"></div>
						<div class="absolute bottom-0 left-0 p-8 z-20">
							<h3 class="text-2xl font-bold text-white mb-2">SaaS Cost Estimator Tool</h3>
							<p class="text-zinc-300 text-sm mb-4">Built and deployed in 14 days to validate market demand.</p>
							<a href="#" class="text-indigo-400 font-semibold group-hover:underline">Read Case Study &rarr;</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		{/* TESTIMONIALS */}
		<section class="py-24 px-8 border-t border-zinc-900">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<svg class="w-12 h-12 text-indigo-500 mx-auto mb-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
				<p class="text-2xl md:text-3xl font-medium text-white mb-8 leading-relaxed">
					"The speed at which omnidevx delivered our MVP was staggering. We were able to start onboarding beta users and pitching investors weeks ahead of schedule."
				</p>
				<div>
					<p class="font-bold text-white">Sarah Jenkins</p>
					<p class="text-zinc-500 text-sm">Founder, StartupX</p>
				</div>
			</div>
		</section>

		{/* FINAL CTA */}
		<section class="py-32 px-8 bg-gradient-to-b from-black to-zinc-950 border-t border-zinc-900">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-5xl md:text-7xl font-black text-white mb-8">Ready to launch?</h2>
				<p class="text-xl text-zinc-400 mb-12">Get an accurate cost and timeline estimate for your MVP using our AI-powered tool.</p>
				<button class="px-10 py-5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-full transition-colors text-xl shadow-[0_0_40px_-10px_rgba(79,70,229,0.5)]">
					Launch AI Estimator &rarr;
				</button>
			</div>
		</section>

	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: { trigger: el, start: 'top 85%' },
			y: 40, opacity: 0, duration: 0.8, ease: 'power3.out'
		});
	});
</script>
