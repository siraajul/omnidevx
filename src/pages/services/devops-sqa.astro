---
import Layout from '../../layouts/Layout.astro';
import { ContainerScroll } from '../../components/sections/container-scroll-animation';
import { DevOpsDashboard } from '../../components/ui/dashboards/DevOpsDashboard';
import { DevOpsFeatures } from '../../components/ui/feature-wrappers';
import { AnimatedProcessFlow } from '../../components/sections/animated-process-flow';
---

<Layout ogImage="/og/services-devops.png">
	<main class="relative w-full overflow-hidden bg-white">
		
		{/* HERO SECTION */}
		<div class="flex flex-col overflow-hidden pt-20 pb-10 md:pt-32 md:pb-20">
			<ContainerScroll client:load>
				<div slot="titleComponent">
					<h1 class="text-4xl md:text-5xl font-semibold text-zinc-900 mb-8">
						<span class="text-orange-600 font-black">DevOps</span> & SQA <br />
						<span class="text-xl md:text-2xl font-normal mt-4 block text-zinc-500 max-w-2xl mx-auto">
							Bulletproof your infrastructure with rigorous automated testing and scalable cloud architecture.
						</span>
					</h1>
				</div>
				<DevOpsDashboard />
			</ContainerScroll>
		</div>

		{/* CORE COMPETENCIES */}
		<section class="py-16 border-t border-zinc-200 bg-zinc-50">
			<div class="max-w-6xl mx-auto px-8 text-center mb-8">
				<h2 class="text-3xl md:text-4xl font-black text-zinc-900 mb-4 tracking-tight">Core <span class="text-emerald-600">Competencies</span></h2>
				<p class="text-zinc-500 max-w-xl mx-auto">Bulletproof infrastructure and quality assurance.</p>
			</div>
			<DevOpsFeatures client:visible />
		</section>

		{/* SOCIAL PROOF */}
		<section class="py-12 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto">
				<a href="/portfolio/fieldsync" class="group flex flex-col md:flex-row items-center gap-6 p-6 rounded-2xl border border-zinc-200 bg-zinc-50 hover:border-zinc-300 transition-colors">
					<div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex-shrink-0 flex items-center justify-center">
						<span class="text-zinc-900 font-black text-lg">FS</span>
					</div>
					<div class="flex-1 text-center md:text-left">
						<p class="text-xs font-bold text-zinc-500 uppercase tracking-widest mb-1">Case Study</p>
						<h3 class="text-lg font-bold text-zinc-900 group-hover:text-emerald-600 transition-colors">FieldSync — 24/7 monitoring for 400+ field technicians</h3>
					</div>
					<span class="text-zinc-500 group-hover:text-zinc-900 transition-colors text-sm font-medium flex items-center gap-1 flex-shrink-0">Read story <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
				</a>
			</div>
		</section>

		{/* HOW WE APPROACH IT */}
		<section class="py-24 px-8 border-t border-zinc-200 bg-zinc-50">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-4xl font-bold text-zinc-900 mb-16 text-center gsap-reveal">Our Infrastructure Process</h2>
				
				<AnimatedProcessFlow client:visible />
			</div>
		</section>

		{/* TECH STACK */}
		<section class="py-24 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-3xl font-bold text-zinc-900 mb-6">The DevOps Stack</h2>
				<p class="text-zinc-500 mb-12">Enterprise-grade tools for monitoring, deployment, and testing.</p>
				
				<div class="flex flex-wrap justify-center gap-4">
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/docker/2496ED" class="w-5 h-5" alt="Docker" /> Docker
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/kubernetes/326CE5" class="w-5 h-5" alt="Kubernetes" /> Kubernetes
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/amazonwebservices.svg" class="w-5 h-5" alt="AWS" /> AWS
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/githubactions/2088FF" class="w-5 h-5" alt="GitHub Actions" /> GitHub Actions
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/playwright.svg" class="w-5 h-5" alt="Playwright" /> Playwright
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/datadog/632CA6" class="w-5 h-5" alt="Datadog" /> Datadog
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/sentry/362D59" class="w-5 h-5" alt="Sentry" /> Sentry
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/terraform/844FBA" class="w-5 h-5" alt="Terraform" /> Terraform
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/gitlab/FC6D26" class="w-5 h-5" alt="GitLab CI" /> GitLab CI
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/jenkins/D24939" class="w-5 h-5" alt="Jenkins" /> Jenkins
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/prometheus/E6522C" class="w-5 h-5" alt="Prometheus" /> Prometheus
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/grafana/F46800" class="w-5 h-5" alt="Grafana" /> Grafana
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/cypress/17202C" class="w-5 h-5" alt="Cypress" /> Cypress
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/linux/FCC624" class="w-5 h-5" alt="Linux" /> Linux
					</span>
					<span class="flex items-center gap-2 px-6 py-3 bg-white border border-zinc-200 text-zinc-900 rounded-full font-medium">
						<img src="https://cdn.simpleicons.org/nginx/009639" class="w-5 h-5" alt="NGINX" /> NGINX
					</span>
				</div>
			</div>
		</section>



		{/* TESTIMONIALS */}
		<section class="py-24 px-8 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<svg class="w-12 h-12 text-orange-500 mx-auto mb-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
				<p class="text-2xl md:text-3xl font-medium text-zinc-900 mb-8 leading-relaxed">
					"Since omnidevx took over our DevOps and established our testing pipelines, we haven't had a single critical outage. We ship code on Fridays with zero stress."
				</p>
				<div>
					<p class="font-bold text-zinc-900">James Wilson</p>
					<p class="text-zinc-500 text-sm">VP Engineering, Logistix</p>
				</div>
			</div>
		</section>



		{/* CTA */}
		<section class="py-24 px-8 border-t border-zinc-200 text-center">
			<div class="max-w-2xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-black text-zinc-900 mb-4 tracking-tight">Ready to ship with <span class="text-emerald-600">confidence</span>?</h2>
				<p class="text-zinc-500 mb-8">Let's build infrastructure that never lets you down.</p>
				<a href="/contact" class="inline-flex items-center gap-2 px-10 py-5 bg-emerald-600 hover:bg-emerald-500 text-zinc-900 font-bold rounded-full transition-colors text-lg">
					Book a Call →
				</a>
			</div>
		</section>

	</main>
</Layout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: { trigger: el, start: 'top 85%' },
			y: 40, opacity: 0, duration: 0.8, ease: 'power3.out'
		});
	});
</script>
