---
import Layout from '../layouts/Layout.astro';
import TeamShowcase from '../components/ui/team-showcase';
---

<Layout>
	<main class="relative w-full bg-black min-h-screen flex flex-col pt-16 overflow-hidden">
		{/* HERO */}
		<div class="relative w-full px-8 text-center z-50 shrink-0">
			<h1 class="text-4xl md:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-600 mb-4">
				Our Team
			</h1>
			<p class="text-lg text-zinc-400 max-w-2xl mx-auto">
				Meet the experts behind the code. A collective of passionate engineers and creatives.
			</p>
		</div>

		{/* INTERACTIVE SHOWCASE */}
		<div class="w-full flex-grow relative flex items-center justify-center pt-8">
			<TeamShowcase client:load />
		</div>
	</main>
</Layout>
