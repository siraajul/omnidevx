---
import Layout from '../layouts/Layout.astro';
import TeamShowcase from '../components/sections/team-showcase';
---

<Layout title="Leadership & Team | Omnidevx" ogImage="/og/team.png">
	<main class="relative w-full min-h-screen flex flex-col pt-24 md:pt-40 overflow-hidden">
		{/* HERO */}
		<div class="relative w-full px-8 text-center z-50 shrink-0">
			<h1 class="text-4xl md:text-6xl font-black text-blue-600 mb-4">
				Our Team
			</h1>
			<p class="text-lg text-zinc-600 max-w-2xl mx-auto">
				Meet the experts behind the code. A collective of passionate engineers and creatives.
			</p>
		</div>

		{/* INTERACTIVE SHOWCASE */}
		<div class="w-full flex-grow relative flex items-center justify-center pt-8">
			<TeamShowcase client:load />
		</div>
	</main>
</Layout>
