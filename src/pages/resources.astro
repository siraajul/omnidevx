---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Engineering Resources & Whitepapers | Omnidevx" ogImage="/og/resources.png" description="Download free guides, whitepapers, and technical case studies from our expert engineering team.">
	<main class="relative w-full min-h-screen pt-32 pb-16 px-8 bg-[#FDFCF7]">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-16">
				<h1 class="text-5xl md:text-7xl font-display text-[#161616] mb-6">
					Engineering <span class="scribble-underline text-[#2A6FDB]">Resources</span>
				</h1>
				<p class="text-xl text-[#2A2A2A] max-w-2xl mx-auto">
					In-depth whitepapers, technical guides, and architectural breakdowns to help you scale your products effectively.
				</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{/* RESOURCE CARD 1 */}
				<div class="flex flex-col border border-[#e8e5db] rounded-3xl bg-white overflow-hidden hover:shadow-[0_20px_40px_-15px_rgba(42,111,219,0.12)] transition-shadow">
					<div class="h-48 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center p-8 relative overflow-hidden">
						<svg class="absolute opacity-10 w-64 h-64 -right-10 -bottom-10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14.5v-9l6 4.5-6 4.5z"/></svg>
						<h3 class="text-white text-2xl font-bold z-10 text-center">The 2026 Guide to Migrating Legacy Apps to Next.js</h3>
					</div>
					<div class="p-8 flex flex-col flex-grow">
						<span class="inline-block px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-xs font-bold uppercase tracking-wider w-max mb-4">Whitepaper</span>
						<p class="text-[#444] mb-8 flex-grow">Learn how to modernize legacy monolithic architectures into hyper-fast, edge-deployed Next.js applications without losing SEO rankings or experiencing downtime.</p>
						<form class="space-y-4" action="/api/send-email" method="POST">
							<input type="hidden" name="type" value="resource_download" />
							<input type="hidden" name="resourceName" value="Next.js Migration Guide" />
							<div>
								<label for="email1" class="sr-only">Email address</label>
								<input type="email" id="email1" name="email" required placeholder="Enter your work email" class="w-full px-4 py-3 bg-[#FDFCF7] border border-[#e8e5db] rounded-xl focus:outline-none focus:border-[#2A6FDB] focus:ring-1 focus:ring-[#2A6FDB] transition-all" />
							</div>
							<button type="submit" class="w-full py-3 bg-[#161616] hover:bg-[#2A2A2A] text-white font-bold rounded-xl transition-colors">
								Download PDF
							</button>
						</form>
					</div>
				</div>

				{/* RESOURCE CARD 2 */}
				<div class="flex flex-col border border-[#e8e5db] rounded-3xl bg-white overflow-hidden hover:shadow-[0_20px_40px_-15px_rgba(42,111,219,0.12)] transition-shadow">
					<div class="h-48 bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center p-8 relative overflow-hidden">
						<svg class="absolute opacity-10 w-64 h-64 -right-10 -bottom-10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
						<h3 class="text-white text-2xl font-bold z-10 text-center">HIPAA Compliance Checklist for Engineering Teams</h3>
					</div>
					<div class="p-8 flex flex-col flex-grow">
						<span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-600 rounded-full text-xs font-bold uppercase tracking-wider w-max mb-4">Checklist</span>
						<p class="text-[#444] mb-8 flex-grow">A comprehensive 40-point technical checklist for CTOs and Engineering Managers building healthcare applications that process Protected Health Information (PHI).</p>
						<form class="space-y-4" action="/api/send-email" method="POST">
							<input type="hidden" name="type" value="resource_download" />
							<input type="hidden" name="resourceName" value="HIPAA Compliance Checklist" />
							<div>
								<label for="email2" class="sr-only">Email address</label>
								<input type="email" id="email2" name="email" required placeholder="Enter your work email" class="w-full px-4 py-3 bg-[#FDFCF7] border border-[#e8e5db] rounded-xl focus:outline-none focus:border-[#2A6FDB] focus:ring-1 focus:ring-[#2A6FDB] transition-all" />
							</div>
							<button type="submit" class="w-full py-3 bg-[#161616] hover:bg-[#2A2A2A] text-white font-bold rounded-xl transition-colors">
								Download PDF
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>
