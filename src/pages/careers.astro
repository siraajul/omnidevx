---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="relative w-full min-h-screen bg-black pt-32 pb-16 px-8">
		<div class="max-w-7xl mx-auto">
			<h1 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-600 mb-6">
				Careers
			</h1>
			<p class="text-xl text-zinc-400 max-w-2xl mb-16">
				Join our team of exceptional engineers and designers building the future of the web.
			</p>
			
			<div class="space-y-4">
				{/* Job Listing Placeholders */}
				<a href="#" class="block p-6 bg-zinc-900 border border-zinc-800 rounded-2xl hover:border-indigo-500 hover:bg-zinc-800/50 transition-all flex items-center justify-between">
					<div>
                        <h3 class="text-2xl font-bold text-white mb-1">Senior Frontend Engineer</h3>
                        <p class="text-zinc-400">Remote · Full-time</p>
                    </div>
                    <span class="text-indigo-400 font-medium">Apply &rarr;</span>
				</a>
                <a href="#" class="block p-6 bg-zinc-900 border border-zinc-800 rounded-2xl hover:border-indigo-500 hover:bg-zinc-800/50 transition-all flex items-center justify-between">
					<div>
                        <h3 class="text-2xl font-bold text-white mb-1">Full-Stack Architect</h3>
                        <p class="text-zinc-400">Remote · Full-time</p>
                    </div>
                    <span class="text-indigo-400 font-medium">Apply &rarr;</span>
				</a>
			</div>
		</div>
	</main>
</Layout>
