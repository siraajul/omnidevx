---
import Layout from "../layouts/Layout.astro";
import CustomLanyard from "../components/sections/custom-lanyard";
import { getJobsByDepartment } from "../data/jobs";

const groupedJobs = getJobsByDepartment();
const departments = Object.keys(groupedJobs);
---

<Layout 
	title="Careers | Omnidevx"
	description="Join our team of exceptional engineers and designers building the future of the web."
	ctaType="careers"
	ogImage="/og/careers.png"
>
	<main class="relative w-full min-h-screen bg-[#FDFCF7] pt-32 pb-16 px-8">
		<div class="max-w-7xl mx-auto">
			<div class="text-center md:text-left">
				<h1
					class="text-5xl md:text-7xl font-display text-[#161616] mb-6 tracking-tight"
				>
					Careers
				</h1>
				<p class="text-xl text-[#444] max-w-2xl mb-16 mx-auto md:mx-0">
					Join our team of exceptional engineers and designers building
					the future of the web.
				</p>
			</div>

			{/* 2.5D Custom Lanyard Interactive Physics */}
			<div class="w-full mb-16 relative">
				<CustomLanyard client:load />
			</div>

			<div class="space-y-16">
				{departments.map(department => (
					<div>
						<h2 class="text-2xl font-display text-[#161616] mb-6 uppercase tracking-widest border-b border-[#e8e5db] pb-4">
							{department}
						</h2>
						<div class="space-y-4">
							{groupedJobs[department].map(job => (
								<a
									href={`/careers/${job.slug}`}
									class="block p-8 bg-white border border-[#e8e5db] rounded-3xl hover:border-[#2A6FDB] hover:shadow-lg transition-all flex items-center justify-between group"
								>
									<div>
										<h3 class="text-2xl font-bold text-[#161616] mb-2">
											{job.title}
										</h3>
										<p class="text-[#444] font-medium">
											{job.location} &middot; {job.type}
										</p>
									</div>
									<span class="text-[#2A6FDB] font-bold group-hover:translate-x-1 transition-transform">
										View Role &rarr;
									</span>
								</a>
							))}
						</div>
					</div>
				))}
			</div>
		</div>
	</main>
</Layout>
