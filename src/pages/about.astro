---
import Layout from '../layouts/Layout.astro';
import AnimatedBento from '../components/sections/animated-bento';
import TeamShowcase from '../components/sections/team-showcase';
---

<Layout title="About Us | Omnidevx" ogImage="/og/about.png" description="We are Omnidevx, an AI-First Software Engineering Agency building the future.">
	<main class="relative w-full pt-32 pb-24 overflow-hidden bg-[#FDFCF7]">
        {/* Background Gradients */}
        <div class="absolute top-0 left-0 w-full h-[800px] bg-gradient-to-b from-blue-50/50 to-transparent pointer-events-none -z-10"></div>
        <div class="absolute top-1/3 right-0 w-[600px] h-[600px] bg-cyan-100/30 blur-[150px] rounded-full pointer-events-none -z-10"></div>

		{/* Hero Section */}
		<div class="max-w-7xl mx-auto px-8 relative z-10 text-center mb-24">
            <h1 class="text-5xl md:text-7xl font-display text-[#161616] mb-6 tracking-tight">
                About <span class="scribble-underline text-[#2A6FDB]">Omnidevx.</span>
            </h1>
            <p class="text-xl text-[#2A2A2A] max-w-3xl mx-auto">
                We're a software engineering agency. We don't sell vaporware or buzzwords. We write reliable code, set up stable infrastructure, and ship products that actually work.
            </p>
		</div>

        {/* Mission / Vision Section */}
        <section class="max-w-7xl mx-auto px-8 mb-32 grid grid-cols-1 md:grid-cols-2 gap-12">
            <div class="bg-white p-10 rounded-3xl shadow-sm border border-[#e8e5db]">
                <h2 class="text-3xl font-display text-[#161616] mb-4">Why we exist</h2>
                <p class="text-lg text-[#444] leading-relaxed">
                    Most agency code is notoriously hard to maintain. We started Omnidevx because we were tired of inheriting undocumented, fragile codebases. We build things meant to last beyond the initial hand-off.
                </p>
            </div>
            <div class="bg-white p-10 rounded-3xl shadow-sm border border-[#e8e5db]">
                <h2 class="text-3xl font-display text-[#161616] mb-4">How we operate</h2>
                <p class="text-lg text-[#444] leading-relaxed">
                    We integrate directly into your Slack and your Git repo. You talk to the engineers writing your code, not an account manager. We believe in fast iteration, rigorous testing, and total transparency.
                </p>
            </div>
        </section>

        {/* Link to Culture & Team */}
        <section class="max-w-5xl mx-auto px-8 mb-32 text-center">
            <h2 class="text-4xl font-display text-[#161616] mb-12">Who We Are</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <a href="/culture" class="group block bg-[#111] text-white p-12 rounded-3xl hover:bg-[#2A6FDB] transition-colors relative overflow-hidden">
                    <div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:20px_20px]"></div>
                    <h3 class="text-3xl font-bold mb-4 relative z-10">Our Culture</h3>
                    <p class="text-white/80 relative z-10">Discover the principles and stories that shape how we work.</p>
                    <div class="mt-8 flex justify-end relative z-10">
                        <svg class="w-8 h-8 group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </div>
                </a>
                <a href="/team" class="group block bg-white text-[#161616] border border-[#e8e5db] p-12 rounded-3xl hover:border-[#2A6FDB] transition-colors relative overflow-hidden shadow-sm">
                    <h3 class="text-3xl font-bold mb-4 relative z-10">Our Team</h3>
                    <p class="text-[#444] relative z-10">Meet the leadership and experts driving our engineering excellence.</p>
                    <div class="mt-8 flex justify-end relative z-10">
                        <svg class="w-8 h-8 text-[#2A6FDB] group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </div>
                </a>
            </div>
        </section>

        {/* Quick CTA */}
        <div class="border-t border-[#e8e5db] pt-24 text-center px-8">
            <h2 class="text-4xl font-display text-[#161616] mb-8">Ready to join forces?</h2>
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-[#111] hover:bg-[#2A6FDB] text-white font-bold rounded-full transition-colors text-lg shadow-[0_0_30px_-5px_rgba(0,0,0,0.3)]">
                Start a Conversation
            </a>
        </div>
	</main>
</Layout>
