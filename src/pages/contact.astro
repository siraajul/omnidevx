---
import Layout from '../layouts/Layout.astro';
import ContactFAQ from '../components/ContactFAQ.astro';
---

<Layout>
	<main class="relative w-full bg-black min-h-screen pt-32 pb-24 overflow-hidden">
        {/* Subtle Background Glow */}
        <div class="absolute top-0 left-0 w-full h-[600px] bg-gradient-to-b from-indigo-900/20 to-transparent pointer-events-none -z-10"></div>
        <div class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-purple-600/10 blur-[120px] rounded-full pointer-events-none -z-10"></div>

		<div class="max-w-7xl mx-auto px-8 relative z-10">
            {/* Header */}
            <div class="mb-20">
                <h1 class="text-5xl md:text-7xl font-black text-white mb-6 tracking-tight">
                    Let's start a <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-600">conversation.</span>
                </h1>
                <p class="text-xl text-zinc-400 max-w-2xl">
                    Whether you need a custom AI agent, a high-performance web app, or an enterprise infrastructure overhaul, our engineers are ready to build.
                </p>
            </div>

            <ContactFAQ />
            
		</div>
	</main>
</Layout>
