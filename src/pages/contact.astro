---
import Layout from '../layouts/Layout.astro';
import ProjectInquiry from '../components/sections/project-inquiry.astro';
import FAQWithSpiral from '../components/sections/faq-section';
---

<Layout title="Contact Us | Omnidevx" ogImage="/og/contact.png">
	<main class="relative w-full min-h-screen pt-32 pb-24 overflow-hidden">
        {/* Subtle Background Glow */}
        <div class="absolute top-0 left-0 w-full h-[600px] bg-gradient-to-b from-blue-100/50 to-transparent pointer-events-none -z-10"></div>
        <div class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-cyan-100/50 blur-[120px] rounded-full pointer-events-none -z-10"></div>

		<div class="max-w-7xl mx-auto px-8 relative z-10">
            {/* Header */}
            <div class="mb-10 text-center">
                <h1 class="text-5xl md:text-7xl font-display text-[#161616] mb-6 tracking-tight">
                    Let's start a <br/>
                    <span class="text-[#2A6FDB] scribble-underline">conversation.</span>
                </h1>
            </div>
		</div>

        {/* PROJECT INQUIRY */}
        <div class="mt-[-80px]">
            <ProjectInquiry />
        </div>
		
		<FAQWithSpiral client:visible />
	</main>
</Layout>
