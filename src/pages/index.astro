---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import ContactFAQ from '../components/ContactFAQ.astro';
import AgencyStory from '../components/AgencyStory';
import IndustryRadar from '../components/ui/industry-radar';
import OmnidevxHero from '../components/ui/omnidevx-hero';
import FAQWithSpiral from '../components/ui/faq-section';
import GlobeSection from '../components/ui/globe-section';
import AnimatedBento from '../components/ui/animated-bento';
---

<Layout>
	<main class="relative w-full overflow-hidden">
		
		{/* CINEMATIC HERO SECTION */}
		<OmnidevxHero client:load />

		{/* LOGO MARQUEE */}
		<section class="py-12 border-y border-zinc-200 bg-white/50 overflow-hidden relative">
			<div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#F9F9F7] to-transparent z-10"></div>
			<div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#F9F9F7] to-transparent z-10"></div>
			
			<p class="text-center text-sm font-semibold text-zinc-400 mb-8 uppercase tracking-widest">Trusted by innovative companies</p>
			
			<div class="flex w-[200%] animate-marquee">
				<div class="flex w-1/2 justify-around items-center opacity-60 grayscale">
					<h3 class="text-2xl font-bold text-zinc-900">StartupX</h3>
					<h3 class="text-2xl font-bold text-zinc-900">TechCorp</h3>
					<h3 class="text-2xl font-bold text-zinc-900">FinServe</h3>
					<h3 class="text-2xl font-bold text-zinc-900">GlobalAI</h3>
					<h3 class="text-2xl font-bold text-zinc-900">Nexus</h3>
				</div>
				<div class="flex w-1/2 justify-around items-center opacity-60 grayscale">
					<h3 class="text-2xl font-bold text-zinc-900">StartupX</h3>
					<h3 class="text-2xl font-bold text-zinc-900">TechCorp</h3>
					<h3 class="text-2xl font-bold text-zinc-900">FinServe</h3>
					<h3 class="text-2xl font-bold text-zinc-900">GlobalAI</h3>
					<h3 class="text-2xl font-bold text-zinc-900">Nexus</h3>
				</div>
			</div>
		</section>

		{/* SERVICES BENTO GRID */}
		<section id="services" class="py-32 px-8">
			<div class="max-w-7xl mx-auto">
				<div class="mb-16">
					<h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-6">Our Expertise</h2>
					<p class="text-xl text-zinc-600 max-w-2xl">A full-stack agency equipped to handle every stage of the software development lifecycle.</p>
				</div>
				<AnimatedBento client:visible />
			</div>
		</section>

		{/* AGENCY STORY SCROLL */}
		<div class="relative w-full">
			<AgencyStory client:visible />
		</div>

		{/* INDUSTRY RADAR */}
		<section class="py-32 px-8 relative overflow-hidden bg-white border-y border-zinc-200">
			<div class="max-w-7xl mx-auto relative z-10">
				<div class="mb-16 text-center gsap-reveal">
					<h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-6 uppercase tracking-tight">
						Building Software for <br/>
						<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">Diverse Industry Needs</span>
					</h2>
					<p class="text-xl text-zinc-600 max-w-2xl mx-auto">We provide custom software engineering and intelligent system design across high-growth sectors.</p>
				</div>
				
				<IndustryRadar client:visible />
			</div>
		</section>

		{/* GLOBE SECTION */}
		<GlobeSection client:visible />

		{/* CONTACT */}
		<section id="contact" class="py-32 px-8 relative">
            {/* Background Glow */}
            <div class="absolute top-1/2 left-0 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2"></div>
            
			<div class="max-w-7xl mx-auto relative z-10">
				<div class="mb-16 text-center gsap-reveal">
					<h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-6">Let's talk <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">business.</span></h2>
					<p class="text-xl text-zinc-600 max-w-2xl mx-auto">Get in touch with our technical team or check our frequently asked questions.</p>
				</div>
				
                <ContactFAQ />
			</div>
		</section>

		{/* STANDALONE FAQ */}
		<FAQWithSpiral client:visible />

		{/* FINAL CTA */}
		<section class="py-32 px-8 bg-gradient-to-b from-transparent to-zinc-100 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-5xl md:text-7xl font-black text-zinc-900 mb-8">Ready to start?</h2>
				<p class="text-xl text-zinc-600 mb-12">Stop guessing. Use our AI tool to get a highly accurate estimate of your project's timeline and cost in under 2 minutes.</p>
				<button class="px-10 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-colors text-xl shadow-[0_0_40px_-10px_rgba(37,99,235,0.3)]">
					Launch AI Estimator &rarr;
				</button>
			</div>
		</section>
	</main>
</Layout>

<style>
	.bg-300\% {
		background-size: 300% 300%;
	}
	.animate-gradient {
		animation: gradient 8s ease infinite;
	}
	@keyframes gradient {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
	.animate-marquee {
		animation: marquee 20s linear infinite;
	}
	@keyframes marquee {
		0% { transform: translateX(0%); }
		100% { transform: translateX(-50%); }
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);

	// Initial Hero Animation
	gsap.to('.hero-anim', {
		y: 0,
		opacity: 1,
		duration: 1,
		stagger: 0.15,
		ease: 'power3.out',
		delay: 0.2
	});

	// ScrollTrigger for Bento Grid & CTA
	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: {
				trigger: el,
				start: 'top 85%',
			},
			y: 50,
			opacity: 0,
			duration: 0.8,
			ease: 'power3.out'
		});
	});
</script>
