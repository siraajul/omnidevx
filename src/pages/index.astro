---
import Layout from '../layouts/Layout.astro';
import ContactFAQ from '../components/ContactFAQ.astro';
import AgencyStory from '../components/AgencyStory';
---

<Layout>
	<main class="relative w-full overflow-hidden">
		
		{/* HERO SECTION */}
		<section class="min-h-screen flex flex-col items-center justify-center px-8 bg-black relative pt-20">
			{/* Background Glow */}
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-indigo-600/20 rounded-full blur-[120px] pointer-events-none"></div>

			<div class="relative z-10 max-w-5xl mx-auto text-center">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-900 border border-zinc-800 text-indigo-400 text-sm font-semibold mb-8 hero-anim opacity-0 translate-y-4">
					<span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
					AI-Powered Software Agency
				</div>
				
				<h1 class="text-6xl md:text-8xl font-black text-white leading-tight tracking-tight mb-8 hero-anim opacity-0 translate-y-4">
					We build <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-500 to-indigo-400 bg-300% animate-gradient">intelligent</span> software solutions.
				</h1>
				
				<p class="text-xl md:text-2xl text-zinc-400 max-w-3xl mx-auto mb-12 hero-anim opacity-0 translate-y-4">
					From fast AI-powered MVPs to enterprise-grade web and mobile applications. We architect, build, and scale digital products that dominate markets.
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4 justify-center hero-anim opacity-0 translate-y-4">
					<a href="#services" class="px-8 py-4 bg-white text-black font-bold rounded-full hover:bg-zinc-200 transition-colors text-lg">
						Explore Services
					</a>
					<a href="/process" class="px-8 py-4 bg-zinc-900 border border-zinc-800 text-white font-bold rounded-full hover:bg-zinc-800 transition-colors text-lg">
						Get an Estimate &rarr;
					</a>
				</div>
			</div>
		</section>

		{/* LOGO MARQUEE */}
		<section class="py-12 border-y border-zinc-900 bg-zinc-950/50 overflow-hidden relative">
			<div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-black to-transparent z-10"></div>
			<div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-black to-transparent z-10"></div>
			
			<p class="text-center text-sm font-semibold text-zinc-500 mb-8 uppercase tracking-widest">Trusted by innovative companies</p>
			
			<div class="flex w-[200%] animate-marquee">
				<div class="flex w-1/2 justify-around items-center opacity-40 grayscale">
					<h3 class="text-2xl font-bold text-white">StartupX</h3>
					<h3 class="text-2xl font-bold text-white">TechCorp</h3>
					<h3 class="text-2xl font-bold text-white">FinServe</h3>
					<h3 class="text-2xl font-bold text-white">GlobalAI</h3>
					<h3 class="text-2xl font-bold text-white">Nexus</h3>
				</div>
				<div class="flex w-1/2 justify-around items-center opacity-40 grayscale">
					<h3 class="text-2xl font-bold text-white">StartupX</h3>
					<h3 class="text-2xl font-bold text-white">TechCorp</h3>
					<h3 class="text-2xl font-bold text-white">FinServe</h3>
					<h3 class="text-2xl font-bold text-white">GlobalAI</h3>
					<h3 class="text-2xl font-bold text-white">Nexus</h3>
				</div>
			</div>
		</section>

		{/* SERVICES BENTO GRID */}
		<section id="services" class="py-32 px-8 bg-black">
			<div class="max-w-7xl mx-auto">
				<div class="mb-16">
					<h2 class="text-4xl md:text-5xl font-black text-white mb-6">Our Expertise</h2>
					<p class="text-xl text-zinc-400 max-w-2xl">A full-stack agency equipped to handle every stage of the software development lifecycle.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[300px]">
					
					{/* Card 1: AI Fast MVP */}
					<a href="/services/ai-mvp" class="gsap-reveal md:col-span-2 relative group rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800 p-8 flex flex-col justify-between hover:border-indigo-500 transition-colors cursor-pointer block">
						<div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
						<div class="relative z-10 flex flex-col h-full">
							<div class="flex items-start justify-between mb-auto">
								<div class="w-12 h-12 rounded-2xl bg-indigo-500/20 flex items-center justify-center text-indigo-400 group-hover:scale-110 transition-transform">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
								</div>
								<span class="inline-block px-3 py-1 bg-indigo-500/20 text-indigo-300 text-sm font-bold rounded-full">Flagship Service</span>
							</div>
							<div>
								<h3 class="text-3xl font-bold text-white mb-2 group-hover:text-indigo-400 transition-colors">AI-Powered Fast MVP</h3>
								<p class="text-zinc-400 text-lg max-w-md">Go to market in weeks, not months. We leverage generative AI tools to rapidly prototype, build, and deploy your Minimum Viable Product.</p>
							</div>
						</div>
					</a>

					{/* Card 2: Generative AI */}
					<a href="/services/generative-ai" class="gsap-reveal relative group rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800 p-8 hover:border-purple-500 transition-colors flex flex-col cursor-pointer block">
						<div class="w-12 h-12 rounded-2xl bg-purple-500/20 flex items-center justify-center text-purple-400 mb-auto group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>
						</div>
						<div>
							<h3 class="text-2xl font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">Generative AI</h3>
							<p class="text-zinc-400">Integrating advanced LLMs directly into your products for intelligent automation.</p>
						</div>
					</a>

					{/* Card 3: Web Apps */}
					<a href="/services/web-development" class="gsap-reveal relative group rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800 p-8 hover:border-blue-500 transition-colors flex flex-col cursor-pointer block">
						<div class="w-12 h-12 rounded-2xl bg-blue-500/20 flex items-center justify-center text-blue-400 mb-auto group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
						</div>
						<div>
							<h3 class="text-2xl font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">Web Applications</h3>
							<p class="text-zinc-400">Highly performant, scalable web platforms built with React, Next.js, and Astro.</p>
						</div>
					</a>

					{/* Card 4: Mobile Apps */}
					<a href="/services/mobile-development" class="gsap-reveal relative group rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800 p-8 hover:border-green-500 transition-colors flex flex-col cursor-pointer block">
						<div class="w-12 h-12 rounded-2xl bg-green-500/20 flex items-center justify-center text-green-400 mb-auto group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
						</div>
						<div>
							<h3 class="text-2xl font-bold text-white mb-2 group-hover:text-green-400 transition-colors">Mobile Apps</h3>
							<p class="text-zinc-400">Native iOS and Android applications utilizing React Native for cross-platform efficiency.</p>
						</div>
					</a>

					{/* Card 5: DevOps & SQA */}
					<a href="/services/devops-sqa" class="gsap-reveal relative group rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800 p-8 hover:border-orange-500 transition-colors flex flex-col justify-between cursor-pointer block">
						<div class="w-12 h-12 rounded-2xl bg-orange-500/20 flex items-center justify-center text-orange-400 mb-4 group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
						</div>
						<div>
							<h3 class="text-2xl font-bold text-white mb-2 group-hover:text-orange-400 transition-colors">DevOps & SQA</h3>
							<p class="text-zinc-400 mb-4">Cloud infrastructure (AWS/Vercel), CI/CD, and rigorous Software Quality Assurance.</p>
							<div class="flex gap-2 flex-wrap">
								<span class="px-2 py-1 bg-zinc-800 text-zinc-300 text-xs rounded border border-zinc-700">Docker</span>
								<span class="px-2 py-1 bg-zinc-800 text-zinc-300 text-xs rounded border border-zinc-700">CI/CD</span>
								<span class="px-2 py-1 bg-zinc-800 text-zinc-300 text-xs rounded border border-zinc-700">Testing</span>
							</div>
						</div>
					</a>

				</div>
			</div>
		</section>

		{/* AGENCY STORY SCROLL */}
		<div class="relative w-full">
			<AgencyStory client:load />
		</div>

		{/* CONTACT & FAQ */}
		<section id="contact" class="py-32 px-8 bg-black relative">
            {/* Background Glow */}
            <div class="absolute top-1/2 left-0 w-[500px] h-[500px] bg-indigo-600/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2"></div>
            
			<div class="max-w-7xl mx-auto relative z-10">
				<div class="mb-16 text-center gsap-reveal">
					<h2 class="text-4xl md:text-5xl font-black text-white mb-6">Let's talk <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-500">business.</span></h2>
					<p class="text-xl text-zinc-400 max-w-2xl mx-auto">Get in touch with our technical team or check our frequently asked questions.</p>
				</div>
				
                <ContactFAQ />
			</div>
		</section>

		{/* FINAL CTA */}
		<section class="py-32 px-8 bg-gradient-to-b from-black to-zinc-950 border-t border-zinc-900">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-5xl md:text-7xl font-black text-white mb-8">Ready to start?</h2>
				<p class="text-xl text-zinc-400 mb-12">Stop guessing. Use our AI tool to get a highly accurate estimate of your project's timeline and cost in under 2 minutes.</p>
				<button class="px-10 py-5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-full transition-colors text-xl shadow-[0_0_40px_-10px_rgba(79,70,229,0.5)]">
					Launch AI Estimator &rarr;
				</button>
			</div>
		</section>
	</main>
</Layout>

<style>
	.bg-300\% {
		background-size: 300% 300%;
	}
	.animate-gradient {
		animation: gradient 8s ease infinite;
	}
	@keyframes gradient {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
	.animate-marquee {
		animation: marquee 20s linear infinite;
	}
	@keyframes marquee {
		0% { transform: translateX(0%); }
		100% { transform: translateX(-50%); }
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);

	// Initial Hero Animation
	gsap.to('.hero-anim', {
		y: 0,
		opacity: 1,
		duration: 1,
		stagger: 0.15,
		ease: 'power3.out',
		delay: 0.2
	});

	// ScrollTrigger for Bento Grid & CTA
	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: {
				trigger: el,
				start: 'top 85%',
			},
			y: 50,
			opacity: 0,
			duration: 0.8,
			ease: 'power3.out'
		});
	});
</script>
