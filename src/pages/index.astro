---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import ContactFAQ from '../components/ContactFAQ.astro';
import AgencyStory from '../components/AgencyStory';
import IndustryRadar from '../components/sections/industry-radar';
import OmnidevxHero from '../components/sections/omnidevx-hero';
import FAQWithSpiral from '../components/sections/faq-section';
import GlobeSection from '../components/sections/globe-section';
import AnimatedBento from '../components/sections/animated-bento';
import MagnifiedBento from '../components/sections/magnified-bento';
import { ProcessStack } from '../components/sections/process-stack';
import { WorkShowcase } from '../components/sections/work-showcase';
import MetricsSection from '../components/sections/metrics-section.astro';
import TestimonialsSection from '../components/sections/testimonials-section.astro';
import ProjectInquiry from '../components/sections/project-inquiry.astro';
---

<Layout ogImage="/og/home.png">
	<main class="relative w-full">
		
		{/* CINEMATIC HERO SECTION */}
		<OmnidevxHero client:load />

		{/* LOGO MARQUEE */}
		<section class="py-12 border-y border-[#e8e5db] bg-white/40 overflow-hidden relative">
			<div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#FDFCF7] to-transparent z-10"></div>
			<div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#FDFCF7] to-transparent z-10"></div>
			
			<p class="text-center text-sm font-hand text-[#444] mb-8">trusted by innovative companies</p>
			
			<div class="flex w-max animate-marquee hover:[animation-play-state:paused]">
				{[...Array(4)].map(() => (
					<div class="flex gap-12 md:gap-24 px-6 md:px-12 items-center opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
						{/* Ruby */}
						<div class="flex items-center gap-3 shrink-0">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-rose-500"><path d="M12 22L2 12l10-10 10 10-10 10z" fill="currentColor" /></svg>
							<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Ruby</h3>
						</div>
						{/* Chipset */}
						<div class="flex items-center gap-3 shrink-0">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-blue-500"><path d="M6 6h12v12H6z" fill="currentColor"/><path d="M4 8h2M4 12h2M4 16h2M18 8h2M18 12h2M18 16h2M8 4v2M12 4v2M16 4v2M8 18v2M12 18v2M16 18v2" stroke="currentColor" stroke-width="2"/></svg>
							<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Chipset</h3>
						</div>
						{/* Acme Corp */}
						<div class="flex items-center gap-3 shrink-0">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-indigo-500"><path d="M12 2l9 5v10l-9 5-9-5V7z" fill="currentColor"/></svg>
							<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Acme Corp</h3>
						</div>
						{/* Nexus */}
						<div class="flex items-center gap-3 shrink-0">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-500"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
							<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Nexus</h3>
						</div>
						{/* GlobalAI */}
						<div class="flex items-center gap-3 shrink-0">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-sky-500"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
							<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">GlobalAI</h3>
						</div>
					</div>
				))}
			</div>
		</section>

		{/* COMPANY METRICS */}
		<MetricsSection />

		{/* GLOBE SECTION */}
		<div class="border-y border-[#e8e5db]">
			<GlobeSection client:visible />
		</div>

		{/* SERVICES BENTO GRID */}
		<section id="services" class="py-32 px-8">
			<div class="max-w-7xl mx-auto">
				<div class="mb-16 text-center">
					<h2 class="text-5xl md:text-6xl font-display text-[#161616] mb-6">What we <span class="scribble-underline text-[#2A6FDB]">build</span></h2>
					<p class="text-xl text-[#2A2A2A] max-w-2xl mx-auto">We write code, configure servers, and ship products. Here's what we do best.</p>
				</div>
				<AnimatedBento client:visible />
			</div>
		</section>

		{/* OUR WORK SHOWCASE */}
		<div class="border-t border-[#e8e5db]">
			<WorkShowcase client:visible />
		</div>

		{/* TESTIMONIALS */}
		<TestimonialsSection />

		{/* MID-PAGE CTA */}
		<section class="py-24 px-8 bg-[#161616] text-[#FDFCF7] relative overflow-hidden">
			{/* Tech Grid Background */}
			<div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:40px_40px]"></div>
			{/* Subtle Blue Glow (Performance Optimized: Radial Gradient instead of CSS Blur) */}
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[radial-gradient(circle_at_center,rgba(42,111,219,0.15)_0%,transparent_70%)] pointer-events-none"></div>

			<div class="max-w-4xl mx-auto text-center relative z-10">
				<h2 class="text-4xl md:text-5xl font-display mb-6">Ready to build?</h2>
				<p class="text-xl text-gray-400 mb-10 font-medium max-w-2xl mx-auto">
					Skip the rest of the pitch. Tell us what you're trying to engineer, and we'll tell you if we can help.
				</p>
				<a href="/contact" class="btn-shimmer inline-flex items-center gap-3 px-10 py-5 bg-[#2A6FDB] text-white font-hand rounded-full hover:bg-white hover:text-[#161616] transition-all duration-300 text-xl shadow-[0_0_40px_-10px_rgba(42,111,219,0.5)]">
					Talk to an engineer
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
				</a>
			</div>
		</section>

		{/* AGENCY STORY SCROLL */}
		<div class="relative w-full">
			<AgencyStory client:visible />
		</div>

		{/* PROCESS — STACKING CARDS (naturally follows services: what we do → how we do it) */}
		<section id="process" class="relative w-full bg-white/50 border-t border-[#e8e5db] pt-32 pb-0">
			<div class="max-w-7xl mx-auto text-center px-8 mb-8">
				<h2 class="text-5xl md:text-6xl font-display text-[#161616] mb-6">
					How we <span class="scribble-underline text-[#2A6FDB]">work</span>
				</h2>
				<p class="text-xl text-[#2A2A2A] max-w-2xl mx-auto">
					We don't do agile theater. We talk to you, write the code, and show you what we built.
				</p>
			</div>
			<ProcessStack client:visible />
		</section>

		{/* INDUSTRY RADAR (static grid — visual palette cleanser between two scroll-driven sections) */}
		<section class="py-32 px-8 relative overflow-hidden bg-white/50 border-y border-[#e8e5db]">
			<div class="max-w-7xl mx-auto relative z-10">
				<div class="mb-16 text-center gsap-reveal">
					<h2 class="text-5xl md:text-6xl font-display text-[#161616] mb-6">
						Who we build <br/>
						<span class="scribble-underline text-[#2A6FDB]">software for</span>
					</h2>
					<p class="text-xl text-[#2A2A2A] max-w-2xl mx-auto">We've shipped production code for startups, healthcare networks, and financial institutions.</p>
				</div>
				
				<IndustryRadar client:visible />
			</div>
		</section>

		{/* STANDALONE FAQ */}
		<FAQWithSpiral client:visible />

		{/* PROJECT INQUIRY (Replaces Contact and Final CTA) */}
		<ProjectInquiry />
	</main>
</Layout>

<style>
	.bg-300\% {
		background-size: 300% 300%;
	}
	.animate-gradient {
		animation: gradient 8s ease infinite;
	}
	@keyframes gradient {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
	.animate-marquee {
		animation: marquee 30s linear infinite;
	}
	@keyframes marquee {
		0% { transform: translateX(0%); }
		100% { transform: translateX(-25%); }
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);



	// ScrollTrigger for Bento Grid & CTA
	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: {
				trigger: el,
				start: 'top 85%',
			},
			y: 50,
			opacity: 0,
			duration: 0.8,
			ease: 'power3.out'
		});
	});
</script>
