---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import ContactFAQ from '../components/ContactFAQ.astro';
import AgencyStory from '../components/AgencyStory';
import IndustryRadar from '../components/sections/industry-radar';
import OmnidevxHero from '../components/sections/omnidevx-hero';
import FAQWithSpiral from '../components/sections/faq-section';
import GlobeSection from '../components/sections/globe-section';
import AnimatedBento from '../components/sections/animated-bento';
import MagnifiedBento from '../components/sections/magnified-bento';
import { ProcessStack } from '../components/sections/process-stack';
import { WorkShowcase } from '../components/sections/work-showcase';
---

<Layout ogImage="/og/home.png">
	<main class="relative w-full">
		
		{/* CINEMATIC HERO SECTION */}
		<OmnidevxHero client:load />

		{/* LOGO MARQUEE */}
		<section class="py-12 border-y border-zinc-200 bg-white/50 overflow-hidden relative">
			<div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#F9F9F7] to-transparent z-10"></div>
			<div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#F9F9F7] to-transparent z-10"></div>
			
			<p class="text-center text-sm font-semibold text-zinc-400 mb-8 uppercase tracking-widest">Trusted by innovative companies</p>
			
			<div class="flex w-max animate-marquee">
				<div class="flex gap-12 md:gap-24 px-6 md:px-12 items-center opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
					{/* Ruby */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-rose-500"><path d="M12 22L2 12l10-10 10 10-10 10z" fill="currentColor" /></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Ruby</h3>
					</div>
					{/* Chipset */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-blue-500"><path d="M6 6h12v12H6z" fill="currentColor"/><path d="M4 8h2M4 12h2M4 16h2M18 8h2M18 12h2M18 16h2M8 4v2M12 4v2M16 4v2M8 18v2M12 18v2M16 18v2" stroke="currentColor" stroke-width="2"/></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Chipset</h3>
					</div>
					{/* Acme Corp */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-indigo-500"><path d="M12 2l9 5v10l-9 5-9-5V7z" fill="currentColor"/></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Acme Corp</h3>
					</div>
					{/* Nexus */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-500"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Nexus</h3>
					</div>
					{/* GlobalAI */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-sky-500"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">GlobalAI</h3>
					</div>
				</div>
				<div class="flex gap-12 md:gap-24 px-6 md:px-12 items-center opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
					{/* Ruby */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-rose-500"><path d="M12 22L2 12l10-10 10 10-10 10z" fill="currentColor" /></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Ruby</h3>
					</div>
					{/* Chipset */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-blue-500"><path d="M6 6h12v12H6z" fill="currentColor"/><path d="M4 8h2M4 12h2M4 16h2M18 8h2M18 12h2M18 16h2M8 4v2M12 4v2M16 4v2M8 18v2M12 18v2M16 18v2" stroke="currentColor" stroke-width="2"/></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Chipset</h3>
					</div>
					{/* Acme Corp */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-indigo-500"><path d="M12 2l9 5v10l-9 5-9-5V7z" fill="currentColor"/></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Acme Corp</h3>
					</div>
					{/* Nexus */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-500"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">Nexus</h3>
					</div>
					{/* GlobalAI */}
					<div class="flex items-center gap-3 shrink-0">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-sky-500"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
						<h3 class="text-2xl font-bold text-zinc-900 tracking-tight">GlobalAI</h3>
					</div>
				</div>
			</div>
		</section>

		{/* SERVICES BENTO GRID */}
		<section id="services" class="py-32 px-8">
			<div class="max-w-7xl mx-auto">
				<div class="mb-16 text-center">
					<h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-6 tracking-tight">Our <span class="text-blue-600">Expertise</span></h2>
					<p class="text-xl text-zinc-500 max-w-2xl mx-auto">A full-stack agency equipped to handle every stage of the software development lifecycle.</p>
				</div>
				<AnimatedBento client:visible />
			</div>
		</section>

		{/* OUR WORK SHOWCASE */}
		<div class="border-t border-zinc-200">
			<WorkShowcase client:visible />
		</div>

		{/* PROCESS — STACKING CARDS (naturally follows services: what we do → how we do it) */}
		<section id="process" class="relative w-full bg-white border-t border-zinc-200 pt-32 pb-0">
			<div class="max-w-7xl mx-auto text-center px-8 mb-8">
				<h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-6 tracking-tight">
					Our <span class="text-blue-600">Process</span>
				</h2>
				<p class="text-xl text-zinc-500 max-w-2xl mx-auto">
					How we turn complex requirements into elegant, high-performing software solutions.
				</p>
			</div>
			<ProcessStack client:visible />
		</section>

		{/* INDUSTRY RADAR (static grid — visual palette cleanser between two scroll-driven sections) */}
		<section class="py-32 px-8 relative overflow-hidden bg-white border-y border-zinc-200">
			<div class="max-w-7xl mx-auto relative z-10">
				<div class="mb-16 text-center gsap-reveal">
					<h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-6 tracking-tight">
						Building Software for <br/>
						<span class="text-blue-600">Diverse Industries</span>
					</h2>
					<p class="text-xl text-zinc-500 max-w-2xl mx-auto">We provide custom software engineering and intelligent system design across high-growth sectors.</p>
				</div>
				
				<IndustryRadar client:visible />
			</div>
		</section>

		{/* AGENCY STORY SCROLL (now separated from Process by Industry Radar) */}
		<div class="relative w-full">
			<AgencyStory client:visible />
		</div>

		{/* GLOBE SECTION */}
		<GlobeSection client:visible />

		{/* CONTACT */}
		<section id="contact" class="py-32 px-8 relative">
            {/* Background Glow */}
            <div class="absolute top-1/2 left-0 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2"></div>
            
			<div class="max-w-7xl mx-auto relative z-10">
				<div class="mb-16 text-center gsap-reveal">
					<h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-6 tracking-tight">Let's talk <span class="text-blue-600">business.</span></h2>
					<p class="text-xl text-zinc-500 max-w-2xl mx-auto">Get in touch with our technical team or check our frequently asked questions.</p>
				</div>
				
                <ContactFAQ />
			</div>
		</section>

		{/* STANDALONE FAQ */}
		<FAQWithSpiral client:visible />

		{/* FINAL CTA */}
		<section class="py-32 px-8 bg-gradient-to-b from-transparent to-zinc-100 border-t border-zinc-200">
			<div class="max-w-4xl mx-auto text-center gsap-reveal">
				<h2 class="text-4xl md:text-5xl font-black text-zinc-900 mb-8 tracking-tight">Ready to <span class="text-blue-600">start?</span></h2>
				<p class="text-xl text-zinc-500 mb-12">Stop guessing. Use our AI tool to get a highly accurate estimate of your project's timeline and cost in under 2 minutes.</p>
				<button class="px-10 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full transition-colors text-xl shadow-[0_0_40px_-10px_rgba(37,99,235,0.3)]">
					Launch AI Estimator &rarr;
				</button>
			</div>
		</section>
	</main>
</Layout>

<style>
	.bg-300\% {
		background-size: 300% 300%;
	}
	.animate-gradient {
		animation: gradient 8s ease infinite;
	}
	@keyframes gradient {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
	.animate-marquee {
		animation: marquee 20s linear infinite;
	}
	@keyframes marquee {
		0% { transform: translateX(0%); }
		100% { transform: translateX(-50%); }
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);



	// ScrollTrigger for Bento Grid & CTA
	const revealElements = document.querySelectorAll('.gsap-reveal');
	revealElements.forEach((el) => {
		gsap.from(el, {
			scrollTrigger: {
				trigger: el,
				start: 'top 85%',
			},
			y: 50,
			opacity: 0,
			duration: 0.8,
			ease: 'power3.out'
		});
	});
</script>
