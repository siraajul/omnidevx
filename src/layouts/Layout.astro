---
import '../styles/global.css';
import TrackingScripts from '../components/TrackingScripts.astro';
import { SmoothScroll } from '../components/SmoothScroll';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>omnidevx</title>
		
		{/* Inject Analytics/Tracking via Partytown */}
		<TrackingScripts />
	</head>
	<body class="bg-black text-white antialiased selection:bg-indigo-500 selection:text-white flex flex-col min-h-screen">
		<SmoothScroll client:load>
			<div class="flex-grow">
				<slot />
			</div>
			<Footer />
		</SmoothScroll>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100vh;
	}
</style>
