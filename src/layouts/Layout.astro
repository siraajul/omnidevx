---
import '../styles/global.css';
import TrackingScripts from '../components/TrackingScripts.astro';
import { SmoothScroll } from '../components/SmoothScroll';
import Footer from '../components/Footer.astro';
import GlobalTabbar from '../components/GlobalTabbar.astro';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	canonicalUrl?: string;
	ctaType?: "default" | "careers";
}

const SITE_URL = 'https://omnidevx-iota.vercel.app';
const defaults = {
	title: 'Omnidevx — AI-First Software Engineering Agency', // 55 chars
	description: 'Elite engineering agency building AI-powered MVPs, scalable web & mobile apps, and cloud infrastructure for startups.', // 117 chars
	ogImage: `${SITE_URL}/og-image.png`,
};

const {
	title = defaults.title,
	description = defaults.description,
	ogImage = defaults.ogImage,
	canonicalUrl,
	ctaType = "default",
} = Astro.props;

const canonical = canonicalUrl || new URL(Astro.url.pathname, SITE_URL).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Kalam:wght@300;400;700&display=swap" rel="stylesheet" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content="Omnidevx" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonical} />

		<!-- Favicons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="apple-touch-icon" href="/favicon.svg?v=2" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="Omnidevx" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonical} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Search Engine Verification (add your codes) -->
		<!-- <meta name="google-site-verification" content="YOUR_CODE" /> -->
		<!-- <meta name="msvalidate.01" content="YOUR_CODE" /> -->

		<!-- Structured Data (JSON-LD) -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ProfessionalService",
			"name": "Omnidevx",
			"url": SITE_URL,
			"logo": `${SITE_URL}/favicon.svg`,
			"description": defaults.description,
			"email": "hello@omnidevx.com",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "100 Innovation Drive",
				"addressLocality": "San Francisco",
				"addressRegion": "CA",
				"postalCode": "94111",
				"addressCountry": "US"
			},
			"sameAs": [],
			"serviceType": [
				"AI/ML Development",
				"Web Application Development",
				"Mobile App Development",
				"DevOps & SQA",
				"Generative AI Solutions"
			],
			"areaServed": "Worldwide",
			"priceRange": "$$$$"
		})} />

		<meta name="generator" content={Astro.generator} />

		{/* Inject Analytics/Tracking via Partytown */}
		<TrackingScripts />
	</head>
	<body class="bg-[#FDFCF7] text-[#161616] antialiased selection:bg-[#2A6FDB] selection:text-white flex flex-col min-h-screen overflow-x-hidden w-full relative dot-grid-bg">
		<SmoothScroll client:idle>
			<div class="flex-grow pb-24 md:pb-32">
				<slot />
			</div>
			<Footer ctaType={ctaType} />
		</SmoothScroll>

		{/* GLOBAL NAVIGATION */}
		<GlobalTabbar />

		{/* GLOBAL EASTER EGGS */}
		<script>
			// 1. Dev Console Hack
			const asciiArt = `
   ____                  _     __          _  __
  / __ \\____ ___  ____  (_)___/ /__ _   __| |/ /
 / / / / __ '__ \\/ __ \\/ / __  / _ \\ | / /   / 
/ /_/ / / / / / / / / / / /_/ /  __/ |/ /   |  
\\____/_/ /_/ /_/_/ /_/_/\\__,_/\\___/|___/_/|_|  
			`;
			console.log(
				"%c" + asciiArt,
				"color: #2A6FDB; font-weight: bold; font-family: monospace;"
			);
			console.log(
				"%cAh, looking under the hood? We like that. Mention the secret code 'CONSOLE_HACKER' when you contact us for priority onboarding.",
				"color: #161616; font-size: 14px; padding: 10px; border-left: 4px solid #2A6FDB; background: #FDFCF7;"
			);

			// 2. MVP Rocket Launch Shortcut
			let keystrokes = '';
			const rocket = document.createElement('div');
			rocket.innerHTML = '🚀';
			rocket.style.cssText = `
				position: fixed;
				bottom: -100px;
				left: 50%;
				transform: translateX(-50%);
				font-size: 80px;
				z-index: 9999;
				pointer-events: none;
				transition: bottom 1.5s cubic-bezier(0.5, 0, 0.2, 1);
				filter: drop-shadow(0 20px 10px rgba(0,0,0,0.3));
			`;
			document.body.appendChild(rocket);

			window.addEventListener('keydown', (e) => {
				// Only track alphabetical keys to avoid capturing huge strings
				if (e.key.length === 1 && e.key.match(/[a-z]/i)) {
					keystrokes += e.key.toLowerCase();
					if (keystrokes.length > 3) keystrokes = keystrokes.slice(-3);
					
					if (keystrokes === 'mvp') {
						rocket.style.bottom = '120vh'; // Shoot past top of screen
						setTimeout(() => {
							rocket.style.transition = 'none'; // Snap back
							rocket.style.bottom = '-100px';
							void rocket.offsetWidth; // Force reflow
							rocket.style.transition = 'bottom 1.5s cubic-bezier(0.5, 0, 0.2, 1)';
						}, 1600);
						keystrokes = '';
					}
				}
			});
		</script>
	</body>
</html>
