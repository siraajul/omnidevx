---
import '../styles/global.css';
import TrackingScripts from '../components/TrackingScripts.astro';
import { SmoothScroll } from '../components/SmoothScroll';
import Footer from '../components/Footer.astro';
import GlobalTabbar from '../components/GlobalTabbar.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Omnidevx — Elite Software Engineering Agency</title>
		
		{/* Inject Analytics/Tracking via Partytown */}
		<TrackingScripts />
	</head>
	<body class="bg-[#F9F9F7] text-zinc-900 antialiased selection:bg-blue-500 selection:text-white flex flex-col min-h-screen">
		<SmoothScroll client:load>
			<div class="flex-grow pb-24 md:pb-32">
				<slot />
			</div>
			<Footer />
		</SmoothScroll>

		{/* GLOBAL NAVIGATION */}
		<GlobalTabbar />
	</body>
</html>

