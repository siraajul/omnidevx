---
import Layout from './Layout.astro';

interface Props {
	name: string;
	category: string;
	tagline: string;
	gradient: string;
	accentColor: string;
	accentBg: string;
	ogImage?: string;
}

const { name, category, tagline, gradient, accentColor, accentBg, ogImage } = Astro.props;
---

<Layout title={`${name} — Case Study | Omnidevx`} description={tagline} ogImage={ogImage}>
	<main class="relative w-full">
		
		{/* HERO */}
		<section class={`relative pt-32 pb-20 px-8 bg-gradient-to-br ${gradient} overflow-hidden`}>
			<div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:60px_60px]"></div>
			<div class="max-w-5xl mx-auto relative z-10">
				<a href="/portfolio" class="inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium mb-8 transition-colors">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					Back to Portfolio
				</a>
				<span class={`px-4 py-1.5 bg-white/20 text-white text-xs font-bold rounded-full backdrop-blur-sm mb-6 inline-block tracking-wider uppercase`}>
					{category}
				</span>
				<h1 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tight leading-tight">
					{name}
				</h1>
				<p class="text-xl text-white/80 max-w-2xl">
					{tagline}
				</p>
			</div>
		</section>

		{/* HERO VISUAL */}
		<section class="relative -mt-8 px-8 z-10">
			<div class="max-w-5xl mx-auto">
				<div class="bg-white rounded-2xl shadow-2xl border border-zinc-200 overflow-hidden p-1">
					<div class="bg-zinc-50 rounded-xl p-8 md:p-12">
						<slot name="hero-visual" />
					</div>
				</div>
			</div>
		</section>

		{/* CONTENT SECTIONS */}
		<div class="max-w-5xl mx-auto px-8 py-24 space-y-24">
			<slot />
		</div>

		{/* IMPACT METRICS */}
		<section class="bg-zinc-900 py-24 px-8">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight text-center">
					The <span class={accentColor}>Impact</span>
				</h2>
				<p class="text-zinc-400 text-center mb-16 max-w-xl mx-auto">Measurable results that speak for themselves.</p>
				<slot name="impact" />
			</div>
		</section>

		{/* CTA */}
		<section class="py-24 px-8 text-center">
			<h2 class="text-3xl md:text-4xl font-black text-zinc-900 mb-4 tracking-tight">
				Let's build something <span class="text-blue-600">like this</span>
			</h2>
			<p class="text-zinc-500 mb-8 max-w-md mx-auto">Ready to turn your idea into a production-grade product?</p>
			<div class="flex flex-wrap justify-center gap-4">
				<a href="/contact" class="px-8 py-4 bg-zinc-900 text-white font-bold rounded-full hover:bg-zinc-800 transition-colors text-sm tracking-wide">
					Book a Call →
				</a>
				<a href="/portfolio" class="px-8 py-4 border border-zinc-300 text-zinc-700 font-bold rounded-full hover:bg-zinc-50 transition-colors text-sm tracking-wide">
					See More Work
				</a>
			</div>
		</section>

	</main>
</Layout>
